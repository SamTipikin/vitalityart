---
// /gallery — full catalogue. Paintings grouped into one section per series.
//
// Desktop (lg+): a sticky right rail holds the chip list (wraps freely
// to handle any number of series). Main content column on the left.
// Mobile (< lg): chips collapse to a sticky horizontal bar at the top.
//
// Chips act as anchor navigation — clicking scrolls to the section.
// Currently in-view section is the active chip and shows a progress bar.
import Base from "~/layouts/Base.astro";
import { paintings, seriesList, seriesSlug, type PlaceholderPainting } from "~/playground/_placeholders";

const grouped = new Map<string, PlaceholderPainting[]>();
for (const p of paintings) {
  const slug = seriesSlug(p.series);
  if (!grouped.has(slug)) grouped.set(slug, []);
  grouped.get(slug)!.push(p);
}

const orderedSeries = seriesList
  .filter((s) => s.slug !== "all")
  .map((s) => ({ ...s, works: grouped.get(s.slug) ?? [] }))
  .filter((s) => s.works.length > 0);
---

<Base
  title="Gallery — Vitaly Leshukov"
  description={`The full catalogue of paintings by Vitaly Leshukov. ${paintings.length} works in oil on canvas across ${orderedSeries.length} series.`}
>
  <main class="bg-bone text-ink min-h-screen">
    <!-- Floating bottom nav -->
    <nav
      aria-label="Primary"
      class="fixed left-1/2 -translate-x-1/2 z-50 px-3 sm:px-2"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);"
    >
      <ul class="flex items-stretch gap-1 rounded-full bg-bone/85 backdrop-blur-xl ring-1 ring-ink/15 shadow-[0_10px_40px_-12px_rgba(27,35,48,0.25)] p-1 text-[11px] tracking-[0.2em] uppercase">
        <li class="flex">
          <a href="/" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer">
            Home
          </a>
        </li>
        <li class="flex">
          <a href="/gallery" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink bg-ink/[0.06] cursor-pointer">
            Gallery
          </a>
        </li>
        <li class="flex">
          <a href="/#exhibitions" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer">
            Exhibitions
          </a>
        </li>
        <li class="flex">
          <a
            href="/#contact"
            class="group inline-flex items-center h-11 gap-2 pl-4 pr-1 rounded-full bg-ink text-bone hover:bg-ink/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
          >
            <span>Contact</span>
            <span class="w-9 h-9 rounded-full bg-bone/15 grid place-items-center text-bone group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- ============================================================ -->
    <!-- MOBILE chip bar — sticky horizontal at top, < lg only         -->
    <!-- ============================================================ -->
    <div class="lg:hidden sticky top-0 z-30 bg-bone/85 backdrop-blur-xl border-b border-ink/10">
      <div class="px-6 py-3 overflow-x-auto">
        <ul class="flex items-center gap-1.5 min-w-max">
          {orderedSeries.map((s, i) => (
            <li>
              <a
                href={`#${s.slug}`}
                data-chip={s.slug}
                data-active={i === 0 ? "" : null}
                class="series-chip relative inline-flex items-center gap-1.5 h-9 px-3 rounded-full ring-1 ring-ink/15 text-[11px] tracking-[0.18em] uppercase transition-colors duration-300 cursor-pointer overflow-hidden"
                style="--progress: 0;"
              >
                <span class="relative z-10 chip-label">{s.label}</span>
                <span class="relative z-10 chip-count text-[10px] opacity-50 tabular-nums">({s.works.length})</span>
                <span class="chip-progress absolute inset-0 pointer-events-none rounded-full overflow-hidden" aria-hidden="true"></span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- DESKTOP layout — main column + sticky right rail              -->
    <!-- ============================================================ -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] xl:grid-cols-[1fr_280px] gap-x-12 px-6 md:px-12 lg:px-16 xl:px-24">
      <!-- ===== Main column ===== -->
      <div class="min-w-0">
        <!-- Page header -->
        <section class="pt-16 md:pt-32 pb-8 md:pb-12">
          <div class="grid grid-cols-12 gap-6 md:gap-10 items-end">
            <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
              Catalogue · {paintings.length} works · {orderedSeries.length} series
            </span>
            <h1 class="col-span-12 md:col-span-9 font-display tracking-[-0.02em] uppercase leading-[0.88] text-[18vw] md:text-[12vw] lg:text-[10vw]" data-anim-h2>
              <span class="sr-only">Gallery — all paintings by Vitaly Leshukov</span>
              {["The full", "catalogue."].map((line, i) => (
                <span class="block overflow-hidden" aria-hidden="true">
                  <span class="block anim-line" style={`--i:${i}`}>{line}</span>
                </span>
              ))}
            </h1>
          </div>
        </section>

        <!-- Series sections -->
        {orderedSeries.map((s, i) => (
          <section
            id={s.slug}
            class="pt-24 md:pt-32 pb-16 md:pb-24 scroll-mt-24"
            data-series-section
            data-series-slug={s.slug}
          >
            <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-10 md:mb-14">
              <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/55 tabular-nums">
                Series {String(i + 1).padStart(2, "0")} / {String(orderedSeries.length).padStart(2, "0")} · {s.works.length} works
              </span>
              <h2 class="col-span-12 md:col-span-9 font-display tracking-[-0.02em] uppercase leading-[0.92] text-[14vw] md:text-[7vw] lg:text-[5vw]" data-anim-h2>
                <span class="sr-only">{s.label}</span>
                <span class="block overflow-hidden" aria-hidden="true">
                  <span class="block anim-line" style="--i:0">{s.label}</span>
                </span>
              </h2>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-12 md:gap-x-8 md:gap-y-20">
              {s.works.map((p) => {
                const priceLabel = p.sold
                  ? "Sold"
                  : p.price
                    ? `$${p.price.toLocaleString()}`
                    : "Contact for price";
                const slug = `${seriesSlug(p.title)}-${p.year}`;
                return (
                  <a href={`/gallery/${slug}`} class="tilt-card group block" data-tilt>
                    <div class="tilt-inner relative aspect-[4/5] overflow-hidden bg-ink/[0.04]">
                      <img
                        src={p.image}
                        alt={p.title}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[1.03]"
                        loading="lazy"
                      />
                      {p.sold && (
                        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-ink text-bone text-[10px] tracking-[0.18em] uppercase">
                          Sold
                        </span>
                      )}
                      <div class="absolute bottom-3 right-3 flex flex-col items-end gap-1.5 pointer-events-none opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
                        <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                          {p.medium}
                        </span>
                        <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                          {p.width}×{p.height} cm
                        </span>
                      </div>
                    </div>
                    <div class="mt-3 grid grid-cols-12 gap-2 text-[11px] tracking-[0.2em] uppercase text-ink/65">
                      <span class="col-span-6 md:col-span-7 truncate">{p.title}</span>
                      <span class="col-span-2 text-ink/45">{p.year}</span>
                      <span class={`col-span-4 md:col-span-3 text-right ${p.sold ? "text-ink" : "text-ink/85"}`}>{priceLabel}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ))}
      </div>

      <!-- ===== Right rail (desktop only) ===== -->
      <aside class="hidden lg:block min-w-0 relative">
        <div class="sticky top-24 pt-32 pb-16">
          <span class="block text-[11px] tracking-[0.2em] uppercase text-ink/55 mb-4">
            Series · {orderedSeries.length}
          </span>
          <ul class="flex flex-wrap gap-1.5">
            {orderedSeries.map((s, i) => (
              <li>
                <a
                  href={`#${s.slug}`}
                  data-chip={s.slug}
                  data-active={i === 0 ? "" : null}
                  class="series-chip relative inline-flex items-center gap-1.5 h-9 px-3 rounded-full ring-1 ring-ink/15 text-[11px] tracking-[0.18em] uppercase transition-colors duration-300 cursor-pointer overflow-hidden"
                  style="--progress: 0;"
                >
                  <span class="relative z-10 chip-label">{s.label}</span>
                  <span class="relative z-10 chip-count text-[10px] opacity-50 tabular-nums">({s.works.length})</span>
                  <span class="chip-progress absolute inset-0 pointer-events-none rounded-full overflow-hidden" aria-hidden="true"></span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>

    <!-- Footer -->
    <footer class="bg-bone border-t border-ink/15 mt-12 px-6 md:px-12 lg:px-16 xl:px-24 pt-12 md:pt-16 pb-32 md:pb-32 grid grid-cols-12 gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase text-ink/60">
      <span class="col-span-12 md:col-span-4">© Vitaly Leshukov · 2026</span>
      <a href="/" class="col-span-6 md:col-span-4 hover:text-ink transition-colors duration-500">← Back to home</a>
      <span class="col-span-6 md:col-span-4 text-right">vitalityart.es</span>
    </footer>
  </main>
</Base>

<style>
  /* Lenis required CSS */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-smooth iframe { pointer-events: none; }

  /* mask-reveal-up (per-line) */
  @keyframes anim-line {
    from { opacity: 0; transform: translate3d(0, 30px, 0); filter: blur(6px); }
    to   { opacity: 1; transform: translate3d(0, 0, 0); filter: blur(0); }
  }
  .anim-line {
    opacity: 0;
    animation: anim-line 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i, 0) * 90ms);
    will-change: opacity, transform, filter;
  }
  [data-anim-h2] .anim-line { animation-play-state: paused; }
  [data-anim-h2].is-animated .anim-line { animation-play-state: running; }
  @media (prefers-reduced-motion: reduce) {
    .anim-line { animation: none; opacity: 1; transform: none; filter: none; }
  }

  /* ===== Series chips =====
     Inactive: outlined pill (ring), ink/70 text, transparent bg.
     Hover: ink text, subtle ink wash bg.
     Active: solid ink bg, bone text — unambiguous regardless of surroundings.
  */
  .series-chip {
    color: rgb(27 35 48 / 0.7);
    background: transparent;
  }
  .series-chip:hover {
    color: rgb(27 35 48);
    background: rgb(27 35 48 / 0.04);
  }
  .series-chip[data-active] {
    background: var(--color-ink);
    color: var(--color-bone);
    --ring-color: transparent;
  }
  .series-chip[data-active] .chip-count {
    opacity: 0.6;
  }
  .series-chip[data-active] {
    --tw-ring-color: transparent;
    box-shadow: none;
  }

  /* Progress fill: only on active chip, the WHOLE chip area gets a
     translucent bone wash that grows from left to right based on
     scroll progress through that section. */
  .chip-progress {
    background: transparent;
  }
  .series-chip[data-active] .chip-progress::after {
    content: "";
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(var(--progress, 0));
    background: rgb(255 255 255 / 0.10); /* fff at 10% */
    transition: transform 120ms linear;
  }

  /* ===== Cursor tilt — paintings lean toward the cursor on hover ===== */
  .tilt-card { perspective: 1200px; }
  .tilt-inner {
    transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 600ms cubic-bezier(0.32, 0.72, 0, 1);
    transform-style: preserve-3d;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .tilt-inner { transform: none !important; transition: none !important; }
  }
</style>

<script>
  import Lenis from "lenis";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let lenis: Lenis | null = null;
  if (!reduced) {
    lenis = new Lenis({ lerp: 0.1, wheelMultiplier: 1, smoothWheel: true, syncTouch: false });
    const raf = (time: number) => { lenis?.raf(time); requestAnimationFrame(raf); };
    requestAnimationFrame(raf);
  }

  // Sections (one per series)
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-series-section]"));
  // ALL chips (mobile bar + desktop rail share the same data-chip slugs)
  const chips = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-chip]"));
  // Group chips by slug so we can update both mobile + desktop variants together
  const chipsBySlug = new Map<string, HTMLAnchorElement[]>();
  for (const c of chips) {
    const slug = c.dataset.chip || "";
    if (!chipsBySlug.has(slug)) chipsBySlug.set(slug, []);
    chipsBySlug.get(slug)!.push(c);
  }

  let activeSlug = sections[0]?.dataset.seriesSlug || "";

  const setActive = (slug: string) => {
    for (const [s, group] of chipsBySlug) {
      const isActive = s === slug;
      for (const chip of group) {
        if (isActive) chip.setAttribute("data-active", "");
        else {
          chip.removeAttribute("data-active");
          chip.style.setProperty("--progress", "0");
        }
      }
    }
    // Auto-center the active chip in the mobile horizontal scroller
    const mobileChip = chipsBySlug.get(slug)?.find((c) =>
      c.closest(".lg\\:hidden"),
    );
    if (mobileChip) {
      mobileChip.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    }
  };

  const updateActive = () => {
    const triggerLine = window.innerHeight * 0.3;
    let next = sections[0]?.dataset.seriesSlug || "";
    for (const sec of sections) {
      const rect = sec.getBoundingClientRect();
      if (rect.top <= triggerLine) next = sec.dataset.seriesSlug || next;
    }
    if (next !== activeSlug) {
      activeSlug = next;
      setActive(activeSlug);
    }
  };

  const updateProgress = () => {
    const sec = sections.find((s) => s.dataset.seriesSlug === activeSlug);
    const group = chipsBySlug.get(activeSlug);
    if (!sec || !group) return;
    const rect = sec.getBoundingClientRect();
    const triggerLine = window.innerHeight * 0.3;
    const total = rect.height;
    const passed = triggerLine - rect.top;
    const p = Math.max(0, Math.min(1, passed / total));
    for (const chip of group) chip.style.setProperty("--progress", p.toFixed(3));
  };

  const tick = () => {
    updateActive();
    updateProgress();
  };

  if (lenis) lenis.on("scroll", tick);
  else window.addEventListener("scroll", tick, { passive: true });
  window.addEventListener("resize", tick);
  requestAnimationFrame(tick);

  // Smooth scroll on chip click
  for (const chip of chips) {
    chip.addEventListener("click", (e) => {
      const slug = chip.dataset.chip;
      if (!slug) return;
      const target = document.getElementById(slug);
      if (!target) return;
      e.preventDefault();
      if (lenis) lenis.scrollTo(target, { offset: -80, duration: 1.2 });
      else target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${slug}`);
    });
  }

  // Section H2 reveal on enter
  const h2Els = document.querySelectorAll<HTMLElement>("[data-anim-h2]");
  if (h2Els.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-animated");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.3, rootMargin: "0px 0px -8% 0px" },
    );
    for (const el of h2Els) io.observe(el);
  } else {
    for (const el of h2Els) el.classList.add("is-animated");
  }

  // Honor URL hash on load: pre-activate that section's chip
  const initialHash = window.location.hash.replace("#", "");
  if (initialHash && chipsBySlug.has(initialHash)) {
    activeSlug = initialHash;
    setActive(initialHash);
  }

  // === Cursor tilt — paintings lean toward the mouse on hover ===
  const tiltCards = Array.from(document.querySelectorAll<HTMLElement>("[data-tilt]"));
  if (!reduced && tiltCards.length && window.matchMedia("(hover: hover)").matches) {
    const MAX_DEG = 5;
    for (const card of tiltCards) {
      const inner = card.querySelector<HTMLElement>(".tilt-inner");
      if (!inner) continue;
      const reset = () => {
        inner.style.setProperty("--tilt-x", "0deg");
        inner.style.setProperty("--tilt-y", "0deg");
      };
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width;
        const py = (e.clientY - rect.top) / rect.height;
        const ry = (px - 0.5) * 2 * MAX_DEG;
        const rx = -(py - 0.5) * 2 * MAX_DEG;
        inner.style.setProperty("--tilt-x", `${rx.toFixed(2)}deg`);
        inner.style.setProperty("--tilt-y", `${ry.toFixed(2)}deg`);
      });
      card.addEventListener("mouseleave", reset);
    }
  }
</script>
