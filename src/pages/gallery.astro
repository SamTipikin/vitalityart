---
// /gallery — full catalogue. Paintings are grouped into one section
// per series. Sticky chip bar acts as anchor navigation: clicking
// a chip scrolls smoothly to that section. The currently in-view
// section is highlighted in the chip bar with a progress bar that
// fills as the user scrolls through it.
import Base from "~/layouts/Base.astro";
import { paintings, seriesList, seriesSlug, type PlaceholderPainting } from "~/playground/_placeholders";

// Group paintings by series slug
const grouped = new Map<string, PlaceholderPainting[]>();
for (const p of paintings) {
  const slug = seriesSlug(p.series);
  if (!grouped.has(slug)) grouped.set(slug, []);
  grouped.get(slug)!.push(p);
}

// Order sections by the canonical seriesList order — drop the "all" entry
// and any series that have zero works.
const orderedSeries = seriesList
  .filter((s) => s.slug !== "all")
  .map((s) => ({ ...s, works: grouped.get(s.slug) ?? [] }))
  .filter((s) => s.works.length > 0);
---

<Base
  title="Gallery — Vitaly Leshukov"
  description={`The full catalogue of paintings by Vitaly Leshukov. ${paintings.length} works in oil on canvas across ${orderedSeries.length} series.`}
>
  <main class="bg-bone text-ink min-h-screen">
    <!-- Floating pill nav (same component as home) -->
    <nav
      aria-label="Primary"
      class="fixed left-1/2 -translate-x-1/2 z-50 px-3 sm:px-2"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);"
    >
      <ul class="flex items-stretch gap-1 rounded-full bg-bone/85 backdrop-blur-xl ring-1 ring-ink/15 shadow-[0_10px_40px_-12px_rgba(27,35,48,0.25)] p-1 text-[11px] tracking-[0.2em] uppercase">
        <li class="flex">
          <a href="/" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer">
            Home
          </a>
        </li>
        <li class="flex">
          <a href="/gallery" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink bg-ink/[0.06] cursor-pointer">
            Gallery
          </a>
        </li>
        <li class="flex">
          <a href="/#exhibitions" class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer">
            Exhibitions
          </a>
        </li>
        <li class="flex">
          <a
            href="/#contact"
            class="group inline-flex items-center h-11 gap-2 pl-4 pr-1 rounded-full bg-ink text-bone hover:bg-ink/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
          >
            <span>Contact</span>
            <span class="w-9 h-9 rounded-full bg-bone/15 grid place-items-center text-bone group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- ============================================================ -->
    <!-- Page header                                                  -->
    <!-- ============================================================ -->
    <section class="px-6 md:px-12 lg:px-16 xl:px-24 pt-16 md:pt-32 pb-8 md:pb-12">
      <div class="grid grid-cols-12 gap-6 md:gap-10 items-end">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          Catalogue · {paintings.length} works · {orderedSeries.length} series
        </span>
        <h1 class="col-span-12 md:col-span-9 font-display tracking-[-0.02em] uppercase leading-[0.88] text-[18vw] md:text-[12vw] lg:text-[10vw]" data-anim-h2>
          <span class="sr-only">Gallery — all paintings by Vitaly Leshukov</span>
          {["The full", "catalogue."].map((line, i) => (
            <span class="block overflow-hidden" aria-hidden="true">
              <span class="block anim-line" style={`--i:${i}`}>{line}</span>
            </span>
          ))}
        </h1>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- Sticky series anchor bar                                     -->
    <!-- Chips scroll to their section. Active chip shows a progress  -->
    <!-- bar. Only one chip is "active" at a time.                    -->
    <!-- ============================================================ -->
    <div class="sticky top-0 z-30 bg-bone/85 backdrop-blur-xl border-y border-ink/10">
      <div class="px-6 md:px-12 lg:px-16 xl:px-24 py-4 overflow-x-auto">
        <ul class="flex items-center gap-1.5 min-w-max" data-chip-list>
          {orderedSeries.map((s, i) => (
            <li>
              <a
                href={`#${s.slug}`}
                data-chip={s.slug}
                class={`relative inline-flex items-center gap-1.5 h-9 px-3 rounded-full text-[11px] tracking-[0.18em] uppercase transition-colors duration-300 cursor-pointer overflow-hidden ${i === 0 ? "bg-ink text-bone" : "bg-transparent text-ink/65 hover:text-ink hover:bg-ink/[0.05]"}`}
                style="--progress: 0;"
              >
                <span class="relative z-10">{s.label}</span>
                <span class="relative z-10 text-[10px] opacity-60 tabular-nums">({s.works.length})</span>
                {/* Progress bar — only painted on the active chip via [data-active] */}
                <span
                  class="chip-progress absolute left-0 right-0 bottom-0 h-[2px] origin-left pointer-events-none"
                  aria-hidden="true"
                ></span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- One section per series                                       -->
    <!-- ============================================================ -->
    {orderedSeries.map((s, i) => (
      <section
        id={s.slug}
        class="px-6 md:px-12 lg:px-16 xl:px-24 pt-24 md:pt-32 pb-24 md:pb-32 scroll-mt-24"
        data-series-section
        data-series-slug={s.slug}
      >
        <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-12 md:mb-16">
          <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/55 tabular-nums">
            Series {String(i + 1).padStart(2, "0")} / {String(orderedSeries.length).padStart(2, "0")} · {s.works.length} works
          </span>
          <h2 class="col-span-12 md:col-span-9 font-display tracking-[-0.02em] uppercase leading-[0.92] text-[14vw] md:text-[7vw] lg:text-[6vw]" data-anim-h2>
            <span class="sr-only">{s.label}</span>
            <span class="block overflow-hidden" aria-hidden="true">
              <span class="block anim-line" style="--i:0">{s.label}</span>
            </span>
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-12 md:gap-x-8 md:gap-y-20">
          {s.works.map((p) => {
            const priceLabel = p.sold
              ? "Sold"
              : p.price
                ? `$${p.price.toLocaleString()}`
                : "Contact for price";
            const slug = `${seriesSlug(p.title)}-${p.year}`;
            return (
              <a href={`/gallery/${slug}`} class="group block">
                <div class="relative aspect-[4/5] overflow-hidden bg-ink/[0.04]">
                  <img
                    src={p.image}
                    alt={p.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                  {p.sold && (
                    <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-ink text-bone text-[10px] tracking-[0.18em] uppercase">
                      Sold
                    </span>
                  )}
                  <div class="absolute bottom-3 right-3 flex flex-col items-end gap-1.5 pointer-events-none opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
                    <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                      {p.medium}
                    </span>
                    <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                      {p.width}×{p.height} cm
                    </span>
                  </div>
                </div>
                <div class="mt-3 grid grid-cols-12 gap-2 text-[11px] tracking-[0.2em] uppercase text-ink/65">
                  <span class="col-span-6 md:col-span-7 truncate">{p.title}</span>
                  <span class="col-span-2 text-ink/45">{p.year}</span>
                  <span class={`col-span-4 md:col-span-3 text-right ${p.sold ? "text-ink" : "text-ink/85"}`}>{priceLabel}</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <!-- ============================================================ -->
    <!-- Footer                                                       -->
    <!-- ============================================================ -->
    <footer class="bg-bone border-t border-ink/15 px-6 md:px-12 lg:px-16 xl:px-24 pt-12 md:pt-16 pb-32 md:pb-32 grid grid-cols-12 gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase text-ink/60">
      <span class="col-span-12 md:col-span-4">© Vitaly Leshukov · 2026</span>
      <a href="/" class="col-span-6 md:col-span-4 hover:text-ink transition-colors duration-500">← Back to home</a>
      <span class="col-span-6 md:col-span-4 text-right">vitalityart.es</span>
    </footer>
  </main>
</Base>

<style>
  /* Lenis required CSS */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-smooth iframe { pointer-events: none; }

  /* mask-reveal-up (per-line) */
  @keyframes anim-line {
    from { opacity: 0; transform: translate3d(0, 30px, 0); filter: blur(6px); }
    to   { opacity: 1; transform: translate3d(0, 0, 0); filter: blur(0); }
  }
  .anim-line {
    opacity: 0;
    animation: anim-line 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i, 0) * 90ms);
    will-change: opacity, transform, filter;
  }
  /* H2 mask-reveal triggered when section enters viewport */
  [data-anim-h2] .anim-line { animation-play-state: paused; }
  [data-anim-h2].is-animated .anim-line { animation-play-state: running; }
  @media (prefers-reduced-motion: reduce) {
    .anim-line { animation: none; opacity: 1; transform: none; filter: none; }
  }

  /* Chip progress — only the active chip shows the bar */
  .chip-progress {
    background: transparent;
    transform: scaleX(0);
    transition: transform 200ms cubic-bezier(0.32, 0.72, 0, 1), background-color 300ms;
  }
  [data-chip][data-active] .chip-progress {
    background: rgba(250, 250, 250, 0.18);
    transform: scaleX(1);
  }
  [data-chip][data-active] .chip-progress::after {
    content: "";
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(var(--progress, 0));
    background: var(--color-bone);
    transition: transform 120ms linear;
  }
</style>

<script>
  import Lenis from "lenis";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let lenis: Lenis | null = null;
  if (!reduced) {
    lenis = new Lenis({ lerp: 0.1, wheelMultiplier: 1, smoothWheel: true, syncTouch: false });
    const raf = (time: number) => { lenis?.raf(time); requestAnimationFrame(raf); };
    requestAnimationFrame(raf);
  }

  // === Series sections + chip anchor navigation ===
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-series-section]"));
  const chips = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-chip]"));
  const chipBySlug = new Map<string, HTMLAnchorElement>();
  for (const c of chips) chipBySlug.set(c.dataset.chip || "", c);

  const setActive = (slug: string) => {
    for (const c of chips) {
      const isActive = c.dataset.chip === slug;
      if (isActive) c.setAttribute("data-active", "");
      else c.removeAttribute("data-active");
      c.classList.toggle("bg-ink", isActive);
      c.classList.toggle("text-bone", isActive);
      c.classList.toggle("text-ink/65", !isActive);
      c.classList.toggle("hover:text-ink", !isActive);
      c.classList.toggle("hover:bg-ink/[0.05]", !isActive);
      // Reset progress on inactive chips so they don't keep stale values
      if (!isActive) c.style.setProperty("--progress", "0");
    }
    // Keep the active chip in view in the horizontal scroller
    const activeChip = chipBySlug.get(slug);
    if (activeChip) {
      activeChip.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    }
  };

  // Track which section is currently active (via "scroll line" ~30% from top)
  let activeSlug = sections[0]?.dataset.seriesSlug || "";

  const updateActive = () => {
    const triggerLine = window.innerHeight * 0.3;
    let next = sections[0]?.dataset.seriesSlug || "";
    for (const sec of sections) {
      const rect = sec.getBoundingClientRect();
      // The last section whose top is above the trigger line wins
      if (rect.top <= triggerLine) {
        next = sec.dataset.seriesSlug || next;
      }
    }
    if (next !== activeSlug) {
      activeSlug = next;
      setActive(activeSlug);
    }
  };

  const updateProgress = () => {
    const sec = sections.find((s) => s.dataset.seriesSlug === activeSlug);
    const chip = chipBySlug.get(activeSlug);
    if (!sec || !chip) return;
    const rect = sec.getBoundingClientRect();
    const triggerLine = window.innerHeight * 0.3;
    // Section progress: 0 when section.top hits triggerLine,
    // 1 when section.bottom hits triggerLine (i.e. fully scrolled past).
    const total = rect.height;
    const passed = triggerLine - rect.top;
    const p = Math.max(0, Math.min(1, passed / total));
    chip.style.setProperty("--progress", p.toFixed(3));
  };

  const tick = () => {
    updateActive();
    updateProgress();
  };

  if (lenis) {
    lenis.on("scroll", tick);
  } else {
    window.addEventListener("scroll", tick, { passive: true });
  }
  window.addEventListener("resize", tick);
  // Initial paint
  requestAnimationFrame(tick);

  // Hook chip clicks into smooth scroll (lenis if available)
  for (const chip of chips) {
    chip.addEventListener("click", (e) => {
      const slug = chip.dataset.chip;
      if (!slug) return;
      const target = document.getElementById(slug);
      if (!target) return;
      e.preventDefault();
      if (lenis) {
        lenis.scrollTo(target, { offset: -80, duration: 1.2 });
      } else {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
      history.replaceState(null, "", `#${slug}`);
    });
  }

  // === H2 mask-reveal on scroll into view ===
  const h2Els = document.querySelectorAll<HTMLElement>("[data-anim-h2]");
  if (h2Els.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-animated");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.3, rootMargin: "0px 0px -8% 0px" },
    );
    for (const el of h2Els) io.observe(el);
  } else {
    for (const el of h2Els) el.classList.add("is-animated");
  }
</script>
