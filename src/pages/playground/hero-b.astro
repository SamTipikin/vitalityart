---
// Variant B — "The Plate"
// Single full-bleed painting on entry. Massive Tanker name overlaps the
// image at the bottom, breaking the container. Quiet metadata strip.
// Reference: Hauser & Wirth, Pace landing pages.
import Base from "~/layouts/Base.astro";
import { paintings, artist } from "~/playground/_placeholders";

const hero = paintings.find((p) => p.title.startsWith("Yin Yang")) || paintings[0];
---

<Base title="Vitaly Leshukov — Hero Variant B">
  <main class="min-h-[100dvh] bg-bone text-ink overflow-hidden">
    <!-- Floating top nav -->
    <header class="absolute top-0 left-0 right-0 z-20 px-6 md:px-10 py-6 flex items-baseline justify-between mix-blend-difference text-bone">
      <span class="font-display text-xl tracking-display uppercase">VL</span>
      <nav class="flex gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase">
        <a href="/" class="hover:opacity-60 transition-opacity duration-500">Origins</a>
        <a href="/gallery" class="hover:opacity-60 transition-opacity duration-500">Gallery</a>
        <a href="#exhibitions" class="hover:opacity-60 transition-opacity duration-500">Exhibitions</a>
        <a href="#contact" class="hover:opacity-60 transition-opacity duration-500">Contact</a>
      </nav>
    </header>

    <!-- Full-bleed painting -->
    <section class="relative w-full h-[100dvh] min-h-[680px]">
      <img
        src={hero.image}
        alt={hero.title}
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
      <!-- Subtle bottom fade so name overlay stays legible on any image -->
      <div class="absolute inset-0 bg-gradient-to-t from-bone/40 via-transparent to-transparent pointer-events-none"></div>

      <!-- Bottom-left credit -->
      <div class="absolute bottom-6 left-6 md:bottom-8 md:left-10 z-10 text-bone text-[11px] tracking-[0.2em] uppercase">
        <span class="block opacity-70">{hero.title}</span>
        <span class="block opacity-50 mt-1">{hero.year} · {hero.width}×{hero.height} cm</span>
      </div>

      <!-- Scroll cue -->
      <div class="absolute bottom-8 right-6 md:right-10 z-10 text-bone text-[10px] tracking-[0.3em] uppercase opacity-70 [writing-mode:vertical-rl] rotate-180">
        Scroll
      </div>
    </section>

    <!-- Name breaks out, sitting on the fold between image and bone -->
    <h1
      class="relative z-10 -mt-[10vw] md:-mt-[7vw] px-4 md:px-8 font-display tracking-display uppercase leading-[0.82] text-[26vw] md:text-[19vw] mix-blend-difference text-bone select-none"
    >
      Leshukov
    </h1>

    <!-- Editorial intro -->
    <section class="px-6 md:px-10 grid grid-cols-12 gap-6 md:gap-10 pt-16 md:pt-24 pb-24 md:pb-32">
      <p class="col-span-12 md:col-span-5 md:col-start-2 font-display text-[6.5vw] md:text-[2.6vw] leading-[1.1] tracking-display max-w-[16ch]">
        "{artist.pullQuote}"
      </p>
      <div class="col-span-12 md:col-span-5 md:col-start-7 max-w-md">
        <span class="block text-[11px] tracking-[0.2em] uppercase text-ink/60 mb-4">Origins</span>
        <p class="text-[15px] md:text-base leading-[1.65] text-ink/85">
          {artist.bioShort}
        </p>
      </div>
    </section>
  </main>
</Base>
