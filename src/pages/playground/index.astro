---
import Base from "~/layouts/Base.astro";

const variants = [
  { path: "/playground/hero-a", name: "A — The Fold", note: "Editorial cover. Big type left, painting right. Asymmetric." },
  { path: "/playground/hero-b", name: "B — The Plate", note: "Full-bleed painting. Name overlaps the fold. Quiet." },
  { path: "/playground/hero-c", name: "C — The Index", note: "Type-first. No hero image. Painting strip below." },
  { path: "/playground/hero-d", name: "D — The Card (Warm)", note: "Collage. Saffron card on blurred painting. Feature plate breaks out." },
  { path: "/playground/hero-e", name: "E — The Card (Cool)", note: "Same comp as D, lime card on iris-tinted backdrop. Closer to ref." },
];
---

<Base title="Playground — Hero Variants">
  <main class="min-h-screen px-8 md:px-12 py-16 max-w-3xl">
    <span class="text-[11px] tracking-[0.2em] uppercase text-ink/60">Playground · Round 01</span>
    <h1 class="font-display tracking-display uppercase text-6xl md:text-7xl mt-3 leading-[0.95]">
      Hero variants
    </h1>
    <p class="mt-6 max-w-md text-ink/75 leading-[1.65]">
      Three takes on the entry to the site. Each one is a different editorial archetype.
      Click in, look at desktop and mobile, and tell me which lane to pursue. We'll iterate
      on the winner before committing.
    </p>

    <ul class="mt-12 space-y-px border-y border-ink/15 divide-y divide-ink/15">
      {variants.map((v, i) => (
        <li>
          <a
            href={v.path}
            class="grid grid-cols-12 gap-4 py-6 hover:bg-ink/[0.025] transition-colors duration-500"
          >
            <span class="col-span-1 text-[11px] tracking-[0.2em] uppercase text-ink/55 pt-1">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="col-span-7 font-display tracking-display uppercase text-3xl md:text-4xl">
              {v.name}
            </span>
            <span class="col-span-12 md:col-span-4 text-sm text-ink/70 leading-[1.55] md:pt-2">
              {v.note}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
