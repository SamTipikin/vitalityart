---
// Variant F — locked direction. Full home-page skeleton +
// text-animation patterns from the animate-text skill:
//   • soft-blur-in (per-character) for the hero name
//   • mask-reveal-up (per-line) for the pull-quote and section H2s
import Base from "~/layouts/Base.astro";
import { paintings, artist, exhibitions } from "~/playground/_placeholders";

const featured = paintings.slice(0, 4);
const feature = featured[0];
const featuredGrid = paintings.slice(0, 6);

// Split helpers — keep template tidy
const chars = (s: string) => Array.from(s);
const heroName1 = chars("Vitaly");
const heroName2 = chars("Leshukov");
const quoteLines = ["After the coma,", "the only thing left", "was color."];

// Marquee — interleave paintings and exhibition labels
type MarqueeItem =
  | { kind: "painting"; src: string; alt: string }
  | { kind: "label"; text: string };
const cities = ["Taipei 2024", "Dubai 2024", "Bordeaux 2024", "Lausanne 2023", "Tokyo 2023", "Madrid 2023", "Valencia 2022"];
const marqueeItems: MarqueeItem[] = [];
const _max = Math.max(paintings.length, cities.length);
for (let i = 0; i < _max; i++) {
  if (i < paintings.length) marqueeItems.push({ kind: "painting", src: paintings[i].image, alt: paintings[i].title });
  if (i < cities.length) marqueeItems.push({ kind: "label", text: cities[i] });
}
---

<Base
  title="Vitaly Leshukov — Painter"
  description="Vitaly Leshukov is a Spanish-based contemporary painter. Oil on canvas. Exhibited in Taipei, Dubai, Bordeaux, Lausanne, Tokyo."
>
  <main class="bg-bone text-ink">
    <!-- ============================================================ -->
    <!-- 01a · TOP WORDMARK (minimal, brand only)                      -->
    <!-- ============================================================ -->
    <header class="px-6 md:px-10 py-6 flex items-baseline justify-between">
      <a href="/" class="font-display text-xl tracking-display uppercase">Vitaly Leshukov</a>
      <span class="text-[11px] tracking-[0.2em] uppercase text-ink/55 hidden sm:inline">Painter · Spain · Est. 2018</span>
    </header>

    <!-- ============================================================ -->
    <!-- 01b · FLOATING PILL NAV (bottom)                              -->
    <!-- Touch targets >=44px, safe-area aware, current section        -->
    <!-- highlighted via IntersectionObserver. Contact is the          -->
    <!-- primary action, visually distinct.                            -->
    <!-- ============================================================ -->
    <nav
      aria-label="Primary"
      class="fixed left-1/2 -translate-x-1/2 z-50 px-3 sm:px-2"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);"
      data-anchor-nav
    >
      <ul class="flex items-stretch gap-1 rounded-full bg-bone/85 backdrop-blur-xl ring-1 ring-ink/15 shadow-[0_10px_40px_-12px_rgba(27,35,48,0.25)] p-1 text-[11px] tracking-[0.2em] uppercase">
        {[
          { href: "#origins", label: "Origins" },
          { href: "#works", label: "Works" },
          { href: "#exhibitions", label: "Exhibitions" },
        ].map((item) => (
          <li class="flex">
            <a
              href={item.href}
              data-anchor-link={item.href}
              class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="flex">
          <a
            href="#contact"
            data-anchor-link="#contact"
            class="group inline-flex items-center h-11 gap-2 pl-4 pr-1 rounded-full bg-ink text-bone hover:bg-ink/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
          >
            <span>Contact</span>
            <span class="w-9 h-9 rounded-full bg-bone/15 grid place-items-center text-bone group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- ============================================================ -->
    <!-- 02 · HERO                                                     -->
    <!-- ============================================================ -->
    <section class="px-4 md:px-10 pt-6 md:pt-10 pb-10 md:pb-16">
      <div class="grid grid-cols-12 gap-4 md:gap-10 items-stretch">
        <!-- Feature painting — auto-rotating cross-fade through 4 works -->
        <figure class="col-span-12 md:col-span-7" data-hero-rotator>
          <div class="relative aspect-[4/5] md:aspect-[5/6] overflow-hidden bg-ink/[0.04]">
            {featured.map((p, i) => (
              <img
                src={p.image}
                alt={`${p.title}, oil on canvas, by Vitaly Leshukov`}
                class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-[1100ms] ease-[cubic-bezier(0.32,0.72,0,1)] ${i === 0 ? "opacity-100" : "opacity-0"}`}
                data-hero-slide={i}
                data-year={p.year}
                data-dims={`${p.width}×${p.height} cm`}
                fetchpriority={i === 0 ? "high" : "auto"}
                loading={i === 0 ? "eager" : "lazy"}
              />
            ))}
          </div>
          <div class="mt-3 md:mt-4 flex items-baseline justify-between text-[11px] tracking-[0.2em] uppercase text-ink/65">
            <span data-hero-title>{feature.title}</span>
            <span class="hidden md:inline" data-hero-year>{feature.year}</span>
            <span data-hero-dims>{feature.width}×{feature.height} cm</span>
          </div>
        </figure>

        <!-- Right column -->
        <div class="col-span-12 md:col-span-5 relative flex flex-col justify-between min-h-[520px] md:min-h-0 md:py-2">
          <!-- Eyebrow -->
          <div class="flex items-center gap-3">
            <span class="block w-6 h-px bg-ink"></span>
            <span class="text-[11px] tracking-[0.2em] uppercase opacity-80">Painter · Spain · est. 2018</span>
          </div>

          <!-- H1: name first (SEO), then divider, then pull quote.
               Per-character soft-blur-in on name, per-line mask-reveal-up on quote. -->
          <h1 class="font-display tracking-[-0.02em] uppercase leading-[0.86] mt-10 md:mt-0">
            <span class="sr-only">Vitaly Leshukov. After the coma, the only thing left was color.</span>

            <span class="block text-[14vw] md:text-[5.6vw] lg:text-[5vw] anim-line-mask" aria-hidden="true">
              {heroName1.map((c, i) => (
                <span class="anim-char inline-block whitespace-pre" style={`--i:${i}`}>{c}</span>
              ))}
            </span>
            <span class="block text-[14vw] md:text-[5.6vw] lg:text-[5vw] anim-line-mask" aria-hidden="true">
              {heroName2.map((c, i) => (
                <span class="anim-char inline-block whitespace-pre" style={`--i:${i + heroName1.length}`}>{c}</span>
              ))}
            </span>

            <span class="block w-12 h-px bg-ink/40 my-5 md:my-6 anim-divider" aria-hidden="true"></span>

            <span class="block text-[7vw] md:text-[2.4vw] leading-[1.1] text-ink/80" aria-hidden="true">
              {quoteLines.map((line, i) => (
                <span class="block overflow-hidden">
                  <span class="block anim-line" style={`--i:${i}`}>{line}</span>
                </span>
              ))}
            </span>
          </h1>

          <!-- Pagination column, right edge — clickable, syncs with rotator -->
          <ol class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 flex-col gap-3 text-[11px] tracking-[0.2em] uppercase items-center" data-hero-pagination>
            {featured.map((_, i) => (
              <>
                <li>
                  <button
                    type="button"
                    data-hero-dot={i}
                    aria-label={`Show painting ${i + 1}`}
                    class={`block py-1 transition-colors duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] ${i === 0 ? "text-ink" : "text-ink/35 hover:text-ink/70"}`}
                  >
                    {String(i + 1).padStart(2, "0")}
                  </button>
                </li>
                {i < featured.length - 1 && <li aria-hidden="true"><span class="block w-px h-4 bg-ink/25"></span></li>}
              </>
            ))}
          </ol>

          <!-- CTA pill -->
          <div class="mt-12 md:mt-14 flex">
            <a
              href="#works"
              class="group inline-flex items-center gap-3 border border-ink rounded-full pl-5 pr-2 py-2 text-[11px] tracking-[0.2em] uppercase transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:translate-y-[-2px] active:scale-[0.98]"
            >
              <span>See the work</span>
              <span class="w-7 h-7 rounded-full bg-ink text-bone grid place-items-center group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 03 · ORIGINS (long-form bio, editorial article style)         -->
    <!-- ============================================================ -->
    <section id="origins" class="border-t border-ink/15 px-6 md:px-10 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="mx-auto max-w-[1200px] grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60 md:sticky md:top-8 md:self-start">
          A 01 — Origins
        </span>
        <div class="col-span-12 md:col-span-8 md:col-start-4">
          <h2 class="font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92] max-w-[14ch]" data-anim-h2>
            <span class="sr-only">From the Urals to oil on canvas</span>
            {["From the", "Urals to oil", "on canvas"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <div class="mt-10 md:mt-14 text-[16px] md:text-[18px] leading-[1.7] text-ink/85 max-w-2xl space-y-5">
            <p class="first-letter:font-display first-letter:text-7xl first-letter:float-left first-letter:leading-[0.9] first-letter:mr-3 first-letter:mt-1 first-letter:uppercase">
              {artist.bioShort}
            </p>
            <p class="text-ink/55 italic">
              [Placeholder. Long-form bio expands here — coma story, return to painting,
              the move to Spain, the language of color. Will be a 3-4 paragraph article
              loaded from Sanity site settings.]
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 03b · MARQUEE — mix of paintings and exhibition labels        -->
    <!-- ============================================================ -->
    <section class="border-t border-b border-ink/15 overflow-hidden py-6 md:py-8" aria-label="Recent paintings and exhibitions">
      <div class="marquee flex gap-8 md:gap-14 whitespace-nowrap will-change-transform items-center">
        {/* Doubled track so the loop is seamless */}
        {[0, 1].map(() => (
          <div class="flex gap-8 md:gap-14 shrink-0 items-center" aria-hidden="true">
            {marqueeItems.map((it) => (
              it.kind === "painting" ? (
                <span class="block h-[18vw] md:h-[14vw] aspect-[4/5] overflow-hidden bg-ink/[0.04] shrink-0">
                  <img src={it.src} alt={it.alt} class="w-full h-full object-cover" loading="lazy" />
                </span>
              ) : (
                <span class="font-display tracking-[-0.02em] uppercase text-[12vw] md:text-[9vw] leading-none flex items-center gap-8 md:gap-14 shrink-0">
                  <span>{it.text}</span>
                  <span class="text-ink/25">✦</span>
                </span>
              )
            ))}
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 04 · FEATURED WORKS                                           -->
    <!-- ============================================================ -->
    <section id="works" class="border-t border-ink/15 px-6 md:px-10 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="mx-auto max-w-[1400px]">
        <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-12 md:mb-20">
          <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
            A 02 — Featured Works
          </span>
          <h2 class="col-span-12 md:col-span-7 font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92]" data-anim-h2>
            <span class="sr-only">Recent paintings</span>
            {["Recent", "paintings"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <a
            href="/gallery"
            class="col-span-12 md:col-span-2 text-[11px] tracking-[0.2em] uppercase border-b border-ink pb-1 hover:opacity-60 transition-opacity duration-500 self-start"
          >
            See all 55 →
          </a>
        </div>

        <!-- Asymmetric editorial grid — varies span, vertical offsets, and parallax speed -->
        <div class="grid grid-cols-12 gap-4 md:gap-6">
          {featuredGrid.map((p, i) => {
            const span = i === 0 ? "md:col-span-7" : i === 1 ? "md:col-span-5" : i === 2 ? "md:col-span-4" : i === 3 ? "md:col-span-8" : i === 4 ? "md:col-span-5" : "md:col-span-7";
            const offset = i === 4 ? "md:mt-16" : i === 3 ? "md:mt-24" : i === 5 ? "md:mt-8" : "";
            // Card-level parallax speeds — alternating, capped subtle range
            const cardSpeed = [0.04, -0.06, 0.08, -0.04, 0.05, -0.07][i % 6];
            // Intra-card image parallax — image is larger than wrapper, scrolls slower
            const imgSpeed = [-0.12, 0.10, -0.08, 0.14, -0.10, 0.08][i % 6];
            const priceLabel = p.sold
              ? "Sold"
              : p.price
                ? `$${p.price.toLocaleString()}`
                : "Contact for price";
            return (
              <a
                href={`/gallery/${p.title.toLowerCase().replace(/\s+/g, "-")}`}
                class={`col-span-12 ${span} ${offset} group block will-change-transform`}
                data-parallax-card
                data-speed={cardSpeed}
              >
                <div class="relative aspect-[4/5] overflow-hidden bg-ink/[0.04]">
                  {/* Image is intentionally larger than wrapper so parallax-y stays inside the frame */}
                  <img
                    src={p.image}
                    alt={p.title}
                    class="absolute inset-0 w-full h-[120%] -top-[10%] object-cover will-change-transform transition-transform duration-[1100ms] ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[1.03]"
                    loading="lazy"
                    data-parallax-img
                    data-speed={imgSpeed}
                  />
                  {/* Museum-label overlay — slides up from bottom on hover */}
                  <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-[700ms] ease-[cubic-bezier(0.32,0.72,0,1)] bg-bone/95 px-4 py-3 flex items-baseline justify-between text-[11px] tracking-[0.2em] uppercase pointer-events-none">
                    <span>{p.medium}</span>
                    <span>{p.width}×{p.height} cm</span>
                  </div>
                </div>
                {/* Caption + price row */}
                <div class="mt-3 grid grid-cols-12 gap-2 text-[11px] tracking-[0.2em] uppercase text-ink/65">
                  <span class="col-span-7 truncate">{p.title}</span>
                  <span class="col-span-2 text-ink/55">{p.year}</span>
                  <span class={`col-span-3 text-right ${p.sold ? "text-ink" : "text-ink/85"}`}>{priceLabel}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 05 · EXHIBITIONS                                              -->
    <!-- ============================================================ -->
    <section id="exhibitions" class="border-t border-ink/15 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="px-6 md:px-10 grid grid-cols-12 gap-6 md:gap-10 mb-12 md:mb-16">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          A 03 — Exhibitions
        </span>
        <h2 class="col-span-12 md:col-span-9 font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92]" data-anim-h2>
          <span class="sr-only">Shown at</span>
          <span class="block overflow-hidden" aria-hidden="true">
            <span class="block anim-line" style="--i:0">Shown at</span>
          </span>
        </h2>
      </div>

      {/* Full-width table, edge-to-edge */}
      <ol class="border-t border-ink/15">
        {exhibitions.slice(0, 6).map((e) => (
          <li class="grid grid-cols-12 gap-4 md:gap-6 px-6 md:px-10 py-5 md:py-7 border-b border-ink/15">
            <span class="col-span-2 md:col-span-1 font-display text-2xl md:text-3xl tracking-display">{e.year}</span>
            <span class="col-span-10 md:col-span-7 text-[15px] md:text-lg">{e.title}</span>
            <span class="col-span-6 md:col-span-2 text-[11px] tracking-[0.2em] uppercase text-ink/60 self-center">{e.type}</span>
            <span class="col-span-6 md:col-span-2 text-[11px] tracking-[0.2em] uppercase text-ink/60 self-center text-right">{e.city}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- ============================================================ -->
    <!-- 06 · CONTACT                                                  -->
    <!-- ============================================================ -->
    <section id="contact" class="border-t border-ink/15 px-6 md:px-10 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="mx-auto max-w-[1200px] grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          A 04 — Contact
        </span>
        <div class="col-span-12 md:col-span-9">
          <h2 class="font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92] max-w-[12ch]" data-anim-h2>
            <span class="sr-only">Acquire or commission</span>
            {["Acquire", "or commission"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <p class="mt-8 max-w-xl text-[16px] md:text-[18px] leading-[1.7] text-ink/80">
            Vitaly accepts a small number of commissions each year and works directly
            with galleries and private collectors. Write below — every message is
            read and replied to.
          </p>
          <p class="mt-12 text-ink/55 italic">[Placeholder. Web3Forms-backed form goes here in Phase 5.]</p>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 07 · FOOTER                                                   -->
    <!-- ============================================================ -->
    <footer class="border-t border-ink/15 px-6 md:px-10 pt-12 md:pt-16 pb-32 md:pb-32 grid grid-cols-12 gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase text-ink/60">
      <span class="col-span-12 md:col-span-4">© Vitaly Leshukov · 2026</span>
      <div class="col-span-6 md:col-span-4 flex flex-col md:flex-row gap-3 md:gap-6">
        <a href="#" class="hover:text-ink transition-colors duration-500">Instagram</a>
        <a href="#" class="hover:text-ink transition-colors duration-500">Facebook</a>
        <a href="#" class="hover:text-ink transition-colors duration-500">TikTok</a>
      </div>
      <span class="col-span-6 md:col-span-4 text-right">vitalityart.es</span>
    </footer>
  </main>
</Base>

<style>
  /* === Lenis smooth scroll required CSS === */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-smooth iframe { pointer-events: none; }

  /* === Marquee — pure CSS, GPU-only via transform === */
  @keyframes marquee {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-50%, 0, 0); }
  }
  .marquee {
    animation: marquee 38s linear infinite;
  }
  .marquee:hover {
    animation-play-state: paused;
  }

  /* === Scroll reveal === */
  [data-reveal] {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    filter: blur(6px);
    transition:
      opacity 900ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 900ms cubic-bezier(0.32, 0.72, 0, 1),
      filter 900ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: opacity, transform, filter;
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }

  /* ============================================================
     Text animations from animate-text skill
     ============================================================ */

  /* === soft-blur-in (per-character) — Apple-signature hero reveal ===
     Spec: enter 900ms, stagger 25ms, ease cubic-bezier(0.22,1,0.36,1)
           from { opacity:0, y:16px, blur:12px } to { 0,0,0 } */
  @keyframes anim-char {
    from {
      opacity: 0;
      transform: translate3d(0, 16px, 0);
      filter: blur(12px);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }
  }
  .anim-char {
    opacity: 0;
    animation: anim-char 900ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i, 0) * 25ms);
    will-change: opacity, transform, filter;
  }
  /* Mask the parent line to clip any sub-pixel bleed during blur */
  .anim-line-mask {
    overflow: hidden;
    padding-bottom: 0.05em;
    margin-bottom: -0.05em;
  }

  /* === mask-reveal-up (per-line) — used on quote + section H2s ===
     Spec: enter 760ms, stagger 90ms, ease cubic-bezier(0.22,1,0.36,1)
           from { opacity:0, y:30px, blur:6px } to { 0,0,0 } */
  @keyframes anim-line {
    from {
      opacity: 0;
      transform: translate3d(0, 30px, 0);
      filter: blur(6px);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }
  }
  .anim-line {
    opacity: 0;
    animation: anim-line 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    /* Hero quote follows the name (~600ms) by default; section H2s reset this via the trigger */
    animation-delay: calc(600ms + var(--i, 0) * 90ms);
    will-change: opacity, transform, filter;
  }

  /* H2s start paused — wait for IntersectionObserver to flip a class */
  [data-anim-h2] .anim-line {
    animation-play-state: paused;
    animation-delay: calc(var(--i, 0) * 90ms);
  }
  [data-anim-h2].is-animated .anim-line {
    animation-play-state: running;
  }

  /* === Hero divider — small fade-in following the name === */
  @keyframes anim-divider {
    from { opacity: 0; transform: scaleX(0.2); }
    to   { opacity: 1; transform: scaleX(1); }
  }
  .anim-divider {
    transform-origin: left center;
    opacity: 0;
    animation: anim-divider 700ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 500ms;
  }

  /* === Reduced motion: hard-cut all === */
  @media (prefers-reduced-motion: reduce) {
    .marquee { animation: none; }
    [data-reveal] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
    .anim-char,
    .anim-line,
    .anim-divider {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }
  }
</style>

<script>
  import Lenis from "lenis";

  // === Lenis smooth scroll ===
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let lenis: Lenis | null = null;

  if (!reduced) {
    lenis = new Lenis({
      lerp: 0.1,
      wheelMultiplier: 1,
      // Touch on mobile: keep native momentum (smoother on iOS)
      smoothWheel: true,
      syncTouch: false,
    });
    const raf = (time: number) => {
      lenis?.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  }

  // === Parallax — card-level + intra-card image ===
  const parallaxCards = Array.from(
    document.querySelectorAll<HTMLElement>("[data-parallax-card]"),
  );
  const parallaxImgs = Array.from(
    document.querySelectorAll<HTMLImageElement>("[data-parallax-img]"),
  );

  const updateParallax = () => {
    const vh = window.innerHeight;
    for (const card of parallaxCards) {
      const rect = card.getBoundingClientRect();
      // Skip if completely off-screen (perf)
      if (rect.bottom < -200 || rect.top > vh + 200) continue;
      const center = rect.top + rect.height / 2;
      const distance = (center - vh / 2) / vh; // ~ -1 .. +1 across viewport
      const speed = parseFloat(card.dataset.speed || "0");
      const y = distance * speed * 100;
      card.style.transform = `translate3d(0, ${y.toFixed(2)}px, 0)`;
    }
    for (const img of parallaxImgs) {
      const cardEl = img.closest<HTMLElement>("[data-parallax-card]");
      if (!cardEl) continue;
      const rect = cardEl.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > vh + 200) continue;
      const center = rect.top + rect.height / 2;
      const distance = (center - vh / 2) / vh;
      const speed = parseFloat(img.dataset.speed || "0");
      const y = distance * speed * 100;
      // Image is 120% tall starting at -10% top — parallax stays inside the frame
      img.style.transform = `translate3d(0, ${y.toFixed(2)}px, 0)`;
    }
  };

  if (!reduced && parallaxCards.length) {
    if (lenis) {
      lenis.on("scroll", updateParallax);
    } else {
      window.addEventListener("scroll", updateParallax, { passive: true });
    }
    window.addEventListener("resize", updateParallax);
    updateParallax();
  }

  // === Hook anchor clicks into lenis for smooth jumps ===
  if (lenis) {
    const anchors = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'),
    );
    for (const a of anchors) {
      a.addEventListener("click", (e) => {
        const href = a.getAttribute("href");
        if (!href || href === "#") return;
        const target = document.querySelector<HTMLElement>(href);
        if (!target) return;
        e.preventDefault();
        lenis!.scrollTo(target, { offset: -96, duration: 1.4 });
        history.pushState(null, "", href);
      });
    }
  }

  // === Section reveal observer ===
  const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
  if (revealEls.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-revealed");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -10% 0px" },
    );
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add("is-revealed"));
  }

  // === H2 mask-reveal-up trigger ===
  const h2Els = document.querySelectorAll<HTMLElement>("[data-anim-h2]");
  if (h2Els.length && "IntersectionObserver" in window) {
    const h2io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-animated");
            h2io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.3, rootMargin: "0px 0px -8% 0px" },
    );
    h2Els.forEach((el) => h2io.observe(el));
  } else {
    h2Els.forEach((el) => el.classList.add("is-animated"));
  }

  // === Active section indicator for floating nav ===
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-anchor-link]"));
  const sectionMap = new Map<string, HTMLAnchorElement>();
  navLinks.forEach((a) => {
    const href = a.getAttribute("data-anchor-link");
    if (href) sectionMap.set(href.replace("#", ""), a);
  });
  const sections = Array.from(sectionMap.keys())
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => Boolean(el));

  if (sections.length && "IntersectionObserver" in window) {
    const setActive = (id: string | null) => {
      navLinks.forEach((a) => {
        const target = a.getAttribute("data-anchor-link")?.replace("#", "");
        const isContact = target === "contact";
        const isActive = target === id;
        if (isContact) return; // Contact button keeps its primary styling
        a.classList.toggle("text-ink", isActive);
        a.classList.toggle("text-ink/70", !isActive);
        a.classList.toggle("bg-ink/[0.06]", isActive);
      });
    };
    const navIo = new IntersectionObserver(
      (entries) => {
        // Prefer the section closest to the middle of the viewport
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length) setActive(visible[0].target.id);
      },
      { rootMargin: "-40% 0px -40% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] },
    );
    sections.forEach((s) => navIo.observe(s));
  }

  // === Hero rotator ===
  const rotator = document.querySelector<HTMLElement>("[data-hero-rotator]");
  if (rotator) {
    const slides = Array.from(rotator.querySelectorAll<HTMLImageElement>("[data-hero-slide]"));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"));
    const titleEl = document.querySelector<HTMLElement>("[data-hero-title]");
    const yearEl = document.querySelector<HTMLElement>("[data-hero-year]");
    const dimsEl = document.querySelector<HTMLElement>("[data-hero-dims]");

    // Read metadata from the data placeholders we already rendered
    const meta = slides.map((img) => ({
      title: img.alt.split(",")[0],
      year: img.dataset.year || "",
      dims: img.dataset.dims || "",
    }));

    let active = 0;
    let timer: number | undefined;
    let paused = false;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const goTo = (next: number) => {
      slides[active].style.opacity = "0";
      slides[next].style.opacity = "1";
      dots.forEach((d, i) => {
        d.classList.toggle("text-ink", i === next);
        d.classList.toggle("text-ink/35", i !== next);
      });
      if (titleEl) titleEl.textContent = meta[next].title;
      if (yearEl) yearEl.textContent = meta[next].year;
      if (dimsEl) dimsEl.textContent = meta[next].dims;
      active = next;
    };

    const tick = () => {
      if (paused) return;
      goTo((active + 1) % slides.length);
    };

    if (!reduced && slides.length > 1) {
      timer = window.setInterval(tick, 6000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        // Reset the auto-cycle so the manual choice gets full time
        if (timer) {
          clearInterval(timer);
          if (!reduced) timer = window.setInterval(tick, 6000);
        }
      });
    });

    rotator.addEventListener("mouseenter", () => { paused = true; });
    rotator.addEventListener("mouseleave", () => { paused = false; });
  }
</script>
