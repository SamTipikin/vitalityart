---
// Variant F — "The Panel" (colorless, multi-line headline)
// Single bone panel. Painting fills the left. Right column carries
// a 5-line stacked Tanker headline (the pull quote, broken),
// pagination column, and an ink-bordered CTA pill.
import Base from "~/layouts/Base.astro";
import { paintings, artist } from "~/playground/_placeholders";

const featured = paintings.slice(0, 4);
const feature = featured[0];

// 5-line stacked headline — short, declarative, broken for typographic rhythm.
const headlineLines = ["AFTER", "THE COMA", "THE ONLY", "THING LEFT", "WAS COLOR"];
---

<Base title="Vitaly Leshukov — Hero Variant F">
  <main class="min-h-[100dvh] bg-bone text-ink">
    <!-- Top nav -->
    <header class="px-6 md:px-10 py-6 flex items-baseline justify-between border-b border-ink/10">
      <span class="font-display text-xl tracking-display uppercase">VL</span>
      <nav class="flex gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase">
        <a href="/" class="hover:opacity-60 transition-opacity duration-500">Origins</a>
        <a href="/gallery" class="hover:opacity-60 transition-opacity duration-500">Gallery</a>
        <a href="#exhibitions" class="hover:opacity-60 transition-opacity duration-500">Exhibitions</a>
        <a href="#contact" class="hover:opacity-60 transition-opacity duration-500">Contact</a>
      </nav>
    </header>

    <!-- Hero panel -->
    <section class="px-4 md:px-10 pt-6 md:pt-10 pb-10 md:pb-14">
      <div class="grid grid-cols-12 gap-4 md:gap-10 items-stretch">
        <!-- Feature painting fills the left -->
        <figure class="col-span-12 md:col-span-7">
          <div class="aspect-[4/5] md:aspect-[5/6] overflow-hidden bg-ink/[0.04]">
            <img
              src={feature.image}
              alt={feature.title}
              class="w-full h-full object-cover"
              fetchpriority="high"
            />
          </div>
          <!-- Caption row -->
          <div class="mt-3 md:mt-4 flex items-baseline justify-between text-[11px] tracking-[0.2em] uppercase text-ink/65">
            <span>{feature.title}</span>
            <span class="hidden md:inline">{feature.year}</span>
            <span>{feature.width}×{feature.height} cm</span>
          </div>
        </figure>

        <!-- Right column -->
        <div class="col-span-12 md:col-span-5 relative flex flex-col justify-between min-h-[460px] md:min-h-0 md:py-2">
          <!-- Eyebrow wordmark -->
          <div class="flex items-center gap-3">
            <span class="block w-6 h-px bg-ink"></span>
            <span class="text-[11px] tracking-[0.2em] uppercase opacity-80">Painter · Spain</span>
          </div>

          <!-- 5-line stacked headline -->
          <h1 class="font-display tracking-[-0.02em] uppercase leading-[0.86] text-[14vw] md:text-[5.6vw] lg:text-[5vw] mt-10 md:mt-0 text-balance">
            {headlineLines.map((line) => (
              <span class="block">{line}</span>
            ))}
          </h1>

          <!-- Attribution -->
          <p class="mt-6 text-[11px] tracking-[0.2em] uppercase text-ink/65">
            — {artist.name}
          </p>

          <!-- Pagination column, right edge -->
          <ol class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 flex-col gap-3 text-[11px] tracking-[0.2em] uppercase items-center">
            {featured.map((_, i) => (
              <li class={`flex flex-col items-center gap-3 ${i === 0 ? "text-ink" : "text-ink/35"}`}>
                <span>{String(i + 1).padStart(2, "0")}</span>
                {i < featured.length - 1 && <span class="block w-px h-4 bg-ink/25"></span>}
              </li>
            ))}
          </ol>

          <!-- CTA pill -->
          <div class="mt-12 md:mt-14 flex">
            <a
              href="/gallery"
              class="group inline-flex items-center gap-3 border border-ink rounded-full pl-5 pr-2 py-2 text-[11px] tracking-[0.2em] uppercase transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:translate-y-[-2px] active:scale-[0.98]"
            >
              <span>See the work</span>
              <span class="w-7 h-7 rounded-full bg-ink text-bone grid place-items-center group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bio strip -->
    <section class="border-t border-ink/10 px-6 md:px-10 py-20 md:py-28">
      <div class="mx-auto max-w-[1200px] grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          Origins
        </span>
        <p class="col-span-12 md:col-span-9 text-[15px] md:text-base leading-[1.7] text-ink/85 max-w-2xl">
          {artist.bioShort}
        </p>
      </div>
    </section>
  </main>
</Base>
