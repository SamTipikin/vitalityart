---
// Variant C — "The Index"
// Type-first. No hero image. Massive Tanker name + pull-quote as the
// entire entry. A horizontal index strip of paintings runs along the
// bottom. Reference: Are.na, It's Nice That, frieze index pages.
import Base from "~/layouts/Base.astro";
import { paintings, artist } from "~/playground/_placeholders";
---

<Base title="Vitaly Leshukov — Hero Variant C">
  <main class="min-h-[100dvh] bg-bone text-ink flex flex-col">
    <!-- Top hairline meta -->
    <div class="grid grid-cols-12 px-6 md:px-10 py-5 border-b border-ink/15 text-[11px] tracking-[0.2em] uppercase">
      <span class="col-span-3">Vitality Art</span>
      <span class="col-span-6 hidden md:block text-center text-ink/55">Painter · Spain</span>
      <span class="col-span-3 text-right text-ink/55">Index 01</span>
    </div>

    <!-- Massive editorial type block -->
    <section class="flex-1 px-6 md:px-10 pt-20 md:pt-32 pb-12">
      <div class="grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60 md:pt-4">
          A 01 — Origins
        </span>

        <h1 class="col-span-12 md:col-span-9 font-display tracking-display uppercase leading-[0.85]">
          <span class="block text-[18vw] md:text-[13vw]">Vitaly</span>
          <span class="block text-[18vw] md:text-[13vw] -mt-[0.05em] text-ink/30">Leshukov</span>
          <span class="block mt-6 md:mt-10 font-display text-[8vw] md:text-[3.4vw] leading-[1.05] max-w-[20ch] tracking-display normal-case lowercase text-ink">
            "{artist.pullQuote}"
          </span>
        </h1>

        <div class="col-span-12 md:col-span-5 md:col-start-4 mt-12 md:mt-16">
          <p class="text-[15px] md:text-base leading-[1.7] text-ink/85 max-w-md">
            {artist.bioShort}
          </p>
        </div>
      </div>
    </section>

    <!-- Painting index strip — horizontal, hairline-divided -->
    <section class="border-t border-ink/15">
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8">
        {paintings.slice(0, 8).map((p, i) => (
          <a
            href="/gallery"
            class={`group flex flex-col gap-3 p-4 md:p-5 border-r border-ink/15 ${i % 2 === 1 ? "border-r" : ""} hover:bg-ink/[0.025] transition-colors duration-500`}
          >
            <div class="aspect-square overflow-hidden bg-ink/[0.04]">
              <img
                src={p.image}
                alt={p.title}
                class="w-full h-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-[11px] tracking-[0.18em] uppercase truncate">{String(i + 1).padStart(2, "0")} — {p.series}</span>
              <span class="text-[11px] text-ink/55 truncate">{p.year} · {p.width}×{p.height}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Base>
