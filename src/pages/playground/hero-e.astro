---
// Variant E — "The Card (Cool)"
// Same composition as D but with a contemporary lime-chartreuse card
// over an ink-blue tint. Closer in mood to Sam's reference image.
import Base from "~/layouts/Base.astro";
import { paintings, artist } from "~/playground/_placeholders";

const backdrop = paintings.find((p) => p.title.startsWith("Against")) || paintings[1];
const feature = paintings.find((p) => p.title.startsWith("Goldfish")) || paintings[3];
const others = paintings.filter((p) => p.title !== feature.title).slice(0, 3);
const allFour = [feature, ...others];
---

<Base title="Vitaly Leshukov — Hero Variant E">
  <main class="min-h-[100dvh] bg-ink text-bone relative overflow-hidden">
    <!-- Backdrop, deeper saturation -->
    <div class="fixed inset-0 -z-10">
      <img
        src={backdrop.image}
        alt=""
        class="w-full h-full object-cover scale-110 blur-[3px] brightness-[0.7] saturate-[1.2]"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-iris/60 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-ink/35"></div>
    </div>

    <!-- Top nav -->
    <header class="relative z-20 px-6 md:px-10 py-6 flex items-baseline justify-between">
      <span class="font-display text-xl tracking-display uppercase">VL</span>
      <nav class="flex gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase">
        <a href="/" class="hover:opacity-60 transition-opacity duration-500">Origins</a>
        <a href="/gallery" class="hover:opacity-60 transition-opacity duration-500">Gallery</a>
        <a href="#exhibitions" class="hover:opacity-60 transition-opacity duration-500">Exhibitions</a>
        <a href="#contact" class="hover:opacity-60 transition-opacity duration-500">Contact</a>
      </nav>
    </header>

    <!-- Inset card -->
    <section class="relative z-10 px-4 md:px-10 pb-20 md:pb-28 pt-6 md:pt-12">
      <div
        class="relative mx-auto max-w-[1280px] bg-lime text-ink rounded-[28px] md:rounded-[36px] p-6 md:p-10 lg:p-14 grid grid-cols-12 gap-6 md:gap-10"
        style="box-shadow: 0 30px 80px -20px rgba(0,0,0,0.5);"
      >
        <!-- Feature painting -->
        <figure class="col-span-12 md:col-span-6 -mt-12 md:-mt-16 md:-ml-6 lg:-ml-10">
          <div class="aspect-[4/5] overflow-hidden rounded-[20px] md:rounded-[24px] bg-ink/10">
            <img
              src={feature.image}
              alt={feature.title}
              class="w-full h-full object-cover"
              fetchpriority="high"
            />
          </div>
          <figcaption class="mt-3 flex justify-between text-[11px] tracking-[0.2em] uppercase text-ink/70">
            <span>{feature.title}</span>
            <span>{feature.width}×{feature.height} cm</span>
          </figcaption>
        </figure>

        <!-- Right column -->
        <div class="col-span-12 md:col-span-6 relative flex flex-col justify-between min-h-[420px] md:min-h-0">
          <div class="flex items-center gap-3">
            <span class="font-display text-base tracking-display uppercase">N°01</span>
            <span class="block w-8 h-px bg-ink/40"></span>
            <span class="text-[11px] tracking-[0.2em] uppercase text-ink/70">Featured</span>
          </div>

          <h1 class="font-display tracking-display uppercase leading-[0.88] text-[12vw] md:text-[5.4vw] lg:text-[4.6vw] mt-8 md:mt-0">
            Vitaly<br />Leshukov
          </h1>

          <p class="mt-6 md:mt-8 max-w-md font-display text-[5vw] md:text-[1.6vw] leading-[1.2] tracking-display">
            "{artist.pullQuote}"
          </p>

          <div class="mt-10 md:mt-12 flex items-end justify-between">
            <a
              href="/gallery"
              class="group inline-flex items-center gap-3 bg-ink text-lime rounded-full pl-5 pr-2 py-2 text-[11px] tracking-[0.2em] uppercase transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:translate-y-[-2px] active:scale-[0.98]"
            >
              <span>See the work</span>
              <span class="w-7 h-7 rounded-full bg-bone/10 grid place-items-center group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
            </a>

            <ol class="flex flex-col gap-2 text-[11px] tracking-[0.2em] uppercase items-end">
              {allFour.map((_, i) => (
                <li class={`flex items-center gap-2 ${i === 0 ? "text-ink" : "text-ink/35"}`}>
                  <span>{String(i + 1).padStart(2, "0")}</span>
                  <span class={`block rounded-full ${i === 0 ? "w-3 h-3 bg-ink" : "w-2 h-2 bg-ink/30"}`}></span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>

      <!-- Bio strip -->
      <div class="mx-auto max-w-[1280px] mt-12 md:mt-16 grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase opacity-70">
          Origins
        </span>
        <p class="col-span-12 md:col-span-7 text-[15px] md:text-base leading-[1.7] opacity-90 max-w-2xl">
          {artist.bioShort}
        </p>
      </div>
    </section>
  </main>
</Base>
