---
// Variant A — "The Fold"
// Editorial magazine cover. Massive Tanker name fills the left half;
// a single hero painting fills the right. Asymmetric. Type breaks
// out under the image. Reference: Apartamento, frieze covers.
import Base from "~/layouts/Base.astro";
import { paintings, artist } from "~/playground/_placeholders";

const hero = paintings.find((p) => p.title.startsWith("Against")) || paintings[0];
---

<Base title="Vitaly Leshukov — Hero Variant A">
  <main class="min-h-[100dvh] bg-bone text-ink">
    <!-- Top meta strip -->
    <div class="px-6 md:px-10 py-6 flex items-baseline justify-between border-b border-ink/10 text-[11px] tracking-[0.2em] uppercase">
      <span>Vitality Art</span>
      <span class="hidden md:inline text-ink/50">Studio · Spain · Est. 2018</span>
      <span class="text-ink/50">N°01 — 2026</span>
    </div>

    <!-- Hero grid -->
    <section class="grid grid-cols-12 gap-6 md:gap-10 px-6 md:px-10 pt-10 md:pt-16 pb-24 md:pb-40">
      <!-- Eyebrow -->
      <div class="col-span-12 md:col-span-7 flex items-center gap-3 mb-2">
        <span class="block w-8 h-px bg-ink"></span>
        <span class="text-[11px] tracking-[0.2em] uppercase text-ink/60">A painter from Spain</span>
      </div>

      <!-- Massive name -->
      <h1 class="col-span-12 md:col-span-7 font-display tracking-display uppercase leading-[0.85] text-[18vw] md:text-[12vw] lg:text-[11vw]">
        Vitaly<br /><span class="block -mt-[0.05em]">Leshukov</span>
      </h1>

      <!-- Hero painting -->
      <figure class="col-span-12 md:col-span-5 md:col-start-8 md:row-start-2 md:row-span-3">
        <div class="aspect-[4/5] md:aspect-[3/5] overflow-hidden bg-ink/[0.04]">
          <img
            src={hero.image}
            alt={hero.title}
            class="w-full h-full object-cover"
            fetchpriority="high"
          />
        </div>
        <figcaption class="mt-3 flex justify-between text-[11px] tracking-widest uppercase text-ink/60">
          <span>{hero.title}</span>
          <span>{hero.width}×{hero.height} cm</span>
        </figcaption>
      </figure>

      <!-- Pull quote -->
      <p class="col-span-12 md:col-span-6 md:col-start-1 md:row-start-3 mt-12 md:mt-24 font-display text-[7vw] md:text-[3.2vw] leading-[1.05] tracking-display max-w-[14ch]">
        "{artist.pullQuote}"
      </p>

      <!-- Body intro -->
      <div class="col-span-12 md:col-span-5 md:col-start-1 md:row-start-4 mt-6 md:mt-12 max-w-md">
        <p class="text-[15px] md:text-base leading-[1.65] text-ink/80">
          {artist.bioShort}
        </p>
        <a
          href="/gallery"
          class="inline-flex items-center gap-3 mt-8 text-[11px] tracking-[0.2em] uppercase border-b border-ink pb-1 hover:text-ink/60 transition-colors duration-500"
        >
          See the work
          <span aria-hidden>→</span>
        </a>
      </div>
    </section>
  </main>
</Base>
