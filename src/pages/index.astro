---
// Variant F — locked direction. Full home-page skeleton +
// text-animation patterns from the animate-text skill:
//   • soft-blur-in (per-character) for the hero name
//   • mask-reveal-up (per-line) for the pull-quote and section H2s
import Base from "~/layouts/Base.astro";
import {
  getAllPaintings,
  getFeaturedPaintings,
  getExhibitions,
  paintingImageUrl,
} from "~/lib/queries";

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;

// Pull live data from Sanity
const [allPaintings, featuredFromSanity, exhibitions, events] = await Promise.all([
  getAllPaintings(),
  getFeaturedPaintings(6),
  getExhibitions("exhibition"),
  getExhibitions("event"),
]);

const featured = featuredFromSanity.slice(0, 4);   // hero rotator
const featuredGrid = featuredFromSanity.slice(0, 6); // home grid
const feature = featured[0];
const totalWorks = allPaintings.length;

// Use the first featured painting's image as the home page OG preview.
// Sanity's image URL builder gives us a sized 1200×630 crop for free.
const homeOgImage = (feature && paintingImageUrl(feature, { width: 1200, quality: 80 })) || undefined;
const homeOgAlt = feature ? `${feature.title}, by Vitaly Leshukov` : "Vitaly Leshukov — paintings";

// Hero artist content — bio lives in Sanity siteSettings later; hardcoded for now.
const artistName = "Vitaly Leshukov";
const artistBioShort =
  "Born in the Urals, working today from Spain. After a coma in 2018, Vitaly returned to the canvas with a single conviction — that paint, large and unflinching, was the only honest record of being alive. The work since has been shown in Taipei, Dubai, Bordeaux, Lausanne, and Tokyo.";

// Split helpers — keep template tidy
const chars = (s: string) => Array.from(s);
const heroName1 = chars("Vitaly");
const heroName2 = chars("Leshukov");
const quoteLines = ["After the coma,", "the only thing left", "was color."];

// Marquee — interleave paintings and exhibition city labels (real data now)
type MarqueeItem =
  | { kind: "painting"; src: string; alt: string }
  | { kind: "label"; text: string };

// Build labels from the real exhibitions: pick distinct city/year combos
const exhibitionLabels = exhibitions
  .slice(0, 8)
  .map((e) => {
    const year = e.date ? new Date(e.date).getFullYear() : "";
    const place = (e.location || "").split(/[,(]/)[0].trim() || e.title;
    return `${place} ${year}`.trim();
  })
  .filter(Boolean);

// Marquee paintings — first 8 with images
const marqueePaintings = allPaintings
  .filter((p) => p.image)
  .slice(0, 8);

const marqueeItems: MarqueeItem[] = [];
const _max = Math.max(marqueePaintings.length, exhibitionLabels.length);
for (let i = 0; i < _max; i++) {
  const p = marqueePaintings[i];
  if (p) {
    const src = paintingImageUrl(p, { width: 600, quality: 80 });
    if (src) marqueeItems.push({ kind: "painting", src, alt: p.title });
  }
  if (i < exhibitionLabels.length) marqueeItems.push({ kind: "label", text: exhibitionLabels[i] });
}
---

<Base
  title="Vitaly Leshukov — Painter"
  description="Vitaly Leshukov is a Spanish-based contemporary painter. Oil on canvas. Exhibited in Taipei, Dubai, Bordeaux, Lausanne, Tokyo."
  ogImage={homeOgImage}
  ogImageAlt={homeOgAlt}
>
  <!-- Fixed gallery overlay — fades in/out as the works section enters/leaves view -->
  <div
    class="fixed inset-0 bg-ink pointer-events-none transition-opacity duration-[900ms] ease-[cubic-bezier(0.32,0.72,0,1)] opacity-0"
    style="z-index: 1;"
    data-gallery-overlay
    aria-hidden="true"
  ></div>

  <main class="relative z-10 text-ink">
    <!-- ============================================================ -->
    <!-- 01 · FLOATING PILL NAV (bottom)                               -->
    <!-- Touch targets >=44px, safe-area aware, current section        -->
    <!-- highlighted via IntersectionObserver. Contact is the          -->
    <!-- primary action, visually distinct.                            -->
    <!-- ============================================================ -->
    <nav
      aria-label="Primary"
      class="fixed left-1/2 -translate-x-1/2 z-50 px-3 sm:px-2"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);"
      data-anchor-nav
    >
      <ul class="flex items-stretch gap-1 rounded-full bg-bone/85 backdrop-blur-xl ring-1 ring-ink/15 shadow-[0_10px_40px_-12px_rgba(27,35,48,0.25)] p-1 text-[11px] tracking-[0.2em] uppercase">
        {[
          { href: "#origins", label: "Origins" },
          { href: "#works", label: "Works" },
          { href: "/gallery", label: "Gallery" },
          { href: "#exhibitions", label: "Exhibitions" },
        ].map((item) => (
          <li class="flex">
            <a
              href={item.href}
              data-anchor-link={item.href}
              class="inline-flex items-center h-11 px-3 sm:px-4 rounded-full text-ink/70 hover:text-ink hover:bg-ink/[0.04] transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="flex">
          <a
            href="#contact"
            data-anchor-link="#contact"
            class="group inline-flex items-center h-11 gap-2 pl-4 pr-1 rounded-full bg-ink text-bone hover:bg-ink/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] cursor-pointer"
          >
            <span>Contact</span>
            <span class="w-9 h-9 rounded-full bg-bone/15 grid place-items-center text-bone group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- ============================================================ -->
    <!-- 02 · HERO — 100vh on desktop, painting cropped to fit         -->
    <!-- ============================================================ -->
    <section class="bg-bone px-4 md:px-10 py-6 md:py-8 md:h-[100vh] md:flex md:flex-col">
      <div class="grid grid-cols-12 gap-4 md:gap-10 items-stretch md:flex-1 md:min-h-0">
        <!-- Feature painting — auto-rotating cross-fade through 4 works -->
        <figure class="col-span-12 md:col-span-7 md:h-full md:min-h-0" data-hero-rotator>
          <div class="relative aspect-[4/5] md:aspect-auto md:h-[calc(100%-2rem)] overflow-hidden bg-ink/[0.04]">
            {featured.map((p, i) => {
              const src = paintingImageUrl(p, { width: 1600, quality: 85 }) ?? "";
              const dims = p.dimensions ? `${p.dimensions.width}×${p.dimensions.height} cm` : "";
              return (
                <img
                  src={src}
                  alt={`${p.title}, oil on canvas, by Vitaly Leshukov`}
                  class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-[1100ms] ease-[cubic-bezier(0.32,0.72,0,1)] ${i === 0 ? "opacity-100" : "opacity-0"}`}
                  data-hero-slide={i}
                  data-year={p.year}
                  data-dims={dims}
                  fetchpriority={i === 0 ? "high" : "auto"}
                  loading={i === 0 ? "eager" : "lazy"}
                />
              );
            })}
          </div>
          <div class="mt-3 md:mt-4 flex items-baseline justify-between text-[11px] tracking-[0.2em] uppercase text-ink/65">
            <span data-hero-title>{feature?.title}</span>
            <span class="hidden md:inline" data-hero-year>{feature?.year}</span>
            <span data-hero-dims>{feature?.dimensions ? `${feature.dimensions.width}×${feature.dimensions.height} cm` : ""}</span>
          </div>
        </figure>

        <!-- Right column -->
        <div class="col-span-12 md:col-span-5 relative flex flex-col justify-between min-h-[520px] md:min-h-0 md:py-4 md:h-full">
          <!-- Eyebrow -->
          <div class="flex items-center gap-3">
            <span class="block w-6 h-px bg-ink"></span>
            <span class="text-[11px] tracking-[0.2em] uppercase opacity-80">Painter · Spain · est. 2018</span>
          </div>

          <!-- H1: name first (SEO), then divider, then pull quote.
               Per-character soft-blur-in on name, per-line mask-reveal-up on quote. -->
          <h1 class="font-display tracking-[-0.02em] uppercase leading-[0.86] mt-10 md:mt-0">
            <span class="sr-only">Vitaly Leshukov. After the coma, the only thing left was color.</span>

            <span class="block text-[14vw] md:text-[5.6vw] lg:text-[5vw] anim-line-mask" aria-hidden="true">
              {heroName1.map((c, i) => (
                <span class="anim-char inline-block whitespace-pre" style={`--i:${i}`}>{c}</span>
              ))}
            </span>
            <span class="block text-[14vw] md:text-[5.6vw] lg:text-[5vw] anim-line-mask" aria-hidden="true">
              {heroName2.map((c, i) => (
                <span class="anim-char inline-block whitespace-pre" style={`--i:${i + heroName1.length}`}>{c}</span>
              ))}
            </span>

            <span class="block w-12 h-px bg-ink/40 my-5 md:my-6 anim-divider" aria-hidden="true"></span>

            <span class="block text-[7vw] md:text-[2.4vw] leading-[1.1] text-ink/80" aria-hidden="true">
              {quoteLines.map((line, i) => (
                <span class="block overflow-hidden">
                  <span class="block anim-line" style={`--i:${i}`}>{line}</span>
                </span>
              ))}
            </span>
          </h1>

          <!-- Pagination column, right edge — clickable, syncs with rotator -->
          <ol class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 flex-col gap-3 text-[11px] tracking-[0.2em] uppercase items-center" data-hero-pagination>
            {featured.map((_, i) => (
              <>
                <li>
                  <button
                    type="button"
                    data-hero-dot={i}
                    aria-label={`Show painting ${i + 1}`}
                    class={`block py-1 transition-colors duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] ${i === 0 ? "text-ink" : "text-ink/35 hover:text-ink/70"}`}
                  >
                    {String(i + 1).padStart(2, "0")}
                  </button>
                </li>
                {i < featured.length - 1 && <li aria-hidden="true"><span class="block w-px h-4 bg-ink/25"></span></li>}
              </>
            ))}
          </ol>

          <!-- CTA pill -->
          <div class="mt-12 md:mt-14 flex">
            <a
              href="#works"
              class="group inline-flex items-center gap-3 border border-ink rounded-full pl-5 pr-2 py-2 text-[11px] tracking-[0.2em] uppercase transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:translate-y-[-2px] active:scale-[0.98]"
            >
              <span>See the work</span>
              <span class="w-7 h-7 rounded-full bg-ink text-bone grid place-items-center group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 03 · ORIGINS (long-form bio, editorial article style)         -->
    <!-- ============================================================ -->
    <section id="origins" class="bg-bone border-t border-ink/15 px-6 md:px-10 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="mx-auto max-w-[1200px] grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60 md:sticky md:top-8 md:self-start">
          A 01 — Origins
        </span>
        <div class="col-span-12 md:col-span-8 md:col-start-4">
          <h2 class="font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92] max-w-[14ch]" data-anim-h2>
            <span class="sr-only">From the Urals to oil on canvas</span>
            {["From the", "Urals to oil", "on canvas"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <div class="mt-10 md:mt-14 text-[16px] md:text-[18px] leading-[1.7] text-ink/85 max-w-2xl space-y-5">
            <p class="first-letter:font-display first-letter:text-7xl first-letter:float-left first-letter:leading-[0.9] first-letter:mr-3 first-letter:mt-1 first-letter:uppercase">
              {artistBioShort}
            </p>
            <p class="text-ink/55 italic">
              [Placeholder. Long-form bio expands here — coma story, return to painting,
              the move to Spain, the language of color. Will be a 3-4 paragraph article
              loaded from Sanity site settings.]
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 03b · MARQUEE — mix of paintings and exhibition labels        -->
    <!-- ============================================================ -->
    <section class="bg-bone border-t border-b border-ink/15 overflow-hidden py-6 md:py-8" aria-label="Recent paintings and exhibitions">
      <div class="flex gap-8 md:gap-14 whitespace-nowrap will-change-transform items-center" data-marquee>
        {/* Doubled track so the loop is seamless */}
        {[0, 1].map(() => (
          <div class="flex gap-8 md:gap-14 shrink-0 items-center" data-marquee-track aria-hidden="true">
            {marqueeItems.map((it) => (
              it.kind === "painting" ? (
                <span class="block h-[18vw] md:h-[14vw] aspect-[4/5] overflow-hidden bg-ink/[0.04] shrink-0">
                  <img src={it.src} alt={it.alt} class="w-full h-full object-cover" loading="lazy" />
                </span>
              ) : (
                <span class="font-display tracking-[-0.02em] uppercase text-[12vw] md:text-[9vw] leading-none flex items-center shrink-0">
                  {it.text}
                </span>
              )
            ))}
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 04 · FEATURED WORKS                                           -->
    <!-- ============================================================ -->
    <section id="works" class="relative z-10 text-bone px-6 md:px-12 lg:px-16 xl:px-24 py-32 md:py-56 scroll-mt-24" data-reveal data-gallery-section>
      <div>
        <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-20 md:mb-32">
          <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-bone/55">
            A 02 — Featured Works
          </span>
          <h2 class="col-span-12 md:col-span-7 font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92]" data-anim-h2>
            <span class="sr-only">Recent paintings</span>
            {["Recent", "paintings"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <a
            href="/gallery"
            class="col-span-12 md:col-span-2 text-[11px] tracking-[0.2em] uppercase border-b border-bone pb-1 hover:opacity-60 transition-opacity duration-500 self-start"
          >
            See all {totalWorks} →
          </a>
        </div>

        <!-- Asymmetric editorial grid — varies span, vertical offsets, and parallax speed -->
        <div class="grid grid-cols-12 gap-y-20 md:gap-y-40 gap-x-10 md:gap-x-24">
          {featuredGrid.map((p, i) => {
            const span = i === 0 ? "md:col-span-7" : i === 1 ? "md:col-span-5" : i === 2 ? "md:col-span-4" : i === 3 ? "md:col-span-8" : i === 4 ? "md:col-span-5" : "md:col-span-7";
            const offset = i === 4 ? "md:mt-32" : i === 3 ? "md:mt-48" : i === 5 ? "md:mt-16" : i === 1 ? "md:mt-12" : "";
            const cardSpeed = [0.40, -0.55, 0.65, -0.40, 0.50, -0.60][i % 6];
            const imgSpeed = [-0.18, 0.14, -0.12, 0.20, -0.16, 0.12][i % 6];
            const priceLabel = p.sold
              ? "Sold"
              : p.price
                ? `$${p.price.toLocaleString()}`
                : "Contact for price";
            const src = paintingImageUrl(p, { width: 1200, quality: 80 });
            const dimensionLabel = p.dimensions ? `${p.dimensions.width}×${p.dimensions.height} cm` : "";
            // Real aspect ratio from the painting's dimensions
            const aspect = p.dimensions?.width && p.dimensions?.height
              ? p.dimensions.width / p.dimensions.height
              : 4 / 5;
            return (
              <a
                href={`/gallery/${p.slug.current}`}
                class={`tilt-card col-span-12 ${span} ${offset} group block will-change-transform`}
                data-parallax-card
                data-speed={cardSpeed}
                data-tilt
              >
                <div class="tilt-inner relative overflow-hidden bg-bone/[0.04]" style={`aspect-ratio: ${aspect};`}>
                  {src && (
                    <img
                      src={src}
                      alt={p.title}
                      class="absolute inset-0 w-full h-[120%] -top-[10%] object-cover will-change-transform"
                      loading="lazy"
                      data-parallax-img
                      data-speed={imgSpeed}
                    />
                  )}
                  <div class="absolute top-3 right-3 md:top-4 md:right-4 flex flex-col items-end gap-1.5 pointer-events-none opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
                    {p.medium && (
                      <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                        {p.medium}
                      </span>
                    )}
                    {dimensionLabel && (
                      <span class="px-2.5 py-1 rounded-full bg-bone/90 backdrop-blur-md ring-1 ring-ink/10 text-[10px] tracking-[0.18em] uppercase text-ink">
                        {dimensionLabel}
                      </span>
                    )}
                  </div>
                </div>
                <div class="mt-4 grid grid-cols-12 gap-2 text-[11px] tracking-[0.2em] uppercase text-bone/70">
                  <span class="col-span-7 truncate">{p.title}</span>
                  <span class="col-span-2 text-bone/45">{p.year}</span>
                  <span class={`col-span-3 text-right ${p.sold ? "text-bone" : "text-bone/90"}`}>{priceLabel}</span>
                </div>
              </a>
            );
          })}
        </div>

        <!-- Bottom CTA — pill button, centered, prominent after the grid -->
        <div class="mt-24 md:mt-40 flex justify-center">
          <a
            href="/gallery"
            class="group inline-flex items-center h-12 gap-3 pl-6 pr-1.5 rounded-full bg-bone text-ink hover:bg-bone/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] text-[11px] tracking-[0.2em] uppercase"
          >
            <span>See all 55 works</span>
            <span class="w-9 h-9 rounded-full bg-ink text-bone grid place-items-center group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 05 · EXHIBITIONS                                              -->
    <!-- ============================================================ -->
    <section id="exhibitions" class="bg-bone border-t border-ink/15 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="px-6 md:px-10 grid grid-cols-12 gap-6 md:gap-10 mb-12 md:mb-16">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          A 03 — Where shown
        </span>
        <h2 class="col-span-12 md:col-span-7 font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92]" data-anim-h2>
          <span class="sr-only">Where shown</span>
          <span class="block overflow-hidden" aria-hidden="true">
            <span class="block anim-line" style="--i:0">Where shown</span>
          </span>
        </h2>

        {/* Tabs — Events / Exhibitions */}
        <div class="col-span-12 md:col-span-2 self-end" data-tabs>
          <div role="tablist" aria-label="Show kind" class="inline-flex items-center rounded-full ring-1 ring-ink/15 p-1 text-[11px] tracking-[0.18em] uppercase">
            <button
              type="button"
              role="tab"
              data-tab="events"
              aria-selected="true"
              class="h-9 px-4 rounded-full bg-ink text-bone transition-colors duration-300 cursor-pointer"
            >
              Events
            </button>
            <button
              type="button"
              role="tab"
              data-tab="exhibitions"
              aria-selected="false"
              class="h-9 px-4 rounded-full text-ink/65 hover:text-ink transition-colors duration-300 cursor-pointer"
            >
              Exhibitions
            </button>
          </div>
        </div>
      </div>

      {/* Events panel (default visible) */}
      <ol class="border-t border-ink/15" data-tab-panel="events">
        {events.map((e) => {
          const year = e.date ? new Date(e.date).getFullYear() : "";
          return (
            <li class="grid grid-cols-12 gap-4 md:gap-6 px-6 md:px-10 py-5 md:py-7 border-b border-ink/15">
              <span class="col-span-2 md:col-span-1 font-display text-2xl md:text-3xl tracking-display">{year}</span>
              <span class="col-span-10 md:col-span-7 text-[15px] md:text-lg">{e.title}</span>
              <span class="col-span-12 md:col-span-4 text-[11px] tracking-[0.2em] uppercase text-ink/60 self-center text-left md:text-right">{e.location}</span>
            </li>
          );
        })}
      </ol>

      {/* Exhibitions panel */}
      <ol class="border-t border-ink/15 hidden" data-tab-panel="exhibitions">
        {exhibitions.map((e) => {
          const year = e.date ? new Date(e.date).getFullYear() : "";
          return (
            <li class="grid grid-cols-12 gap-4 md:gap-6 px-6 md:px-10 py-5 md:py-7 border-b border-ink/15">
              <span class="col-span-2 md:col-span-1 font-display text-2xl md:text-3xl tracking-display">{year}</span>
              <span class="col-span-10 md:col-span-7 text-[15px] md:text-lg">{e.title}</span>
              <span class="col-span-12 md:col-span-4 text-[11px] tracking-[0.2em] uppercase text-ink/60 self-center text-left md:text-right">{e.location}</span>
            </li>
          );
        })}
      </ol>
    </section>

    <!-- ============================================================ -->
    <!-- 06 · CONTACT                                                  -->
    <!-- ============================================================ -->
    <section id="contact" class="bg-bone border-t border-ink/15 px-6 md:px-10 py-24 md:py-40 scroll-mt-24" data-reveal>
      <div class="mx-auto max-w-[1200px] grid grid-cols-12 gap-6 md:gap-10">
        <span class="col-span-12 md:col-span-3 text-[11px] tracking-[0.2em] uppercase text-ink/60">
          A 04 — Contact
        </span>
        <div class="col-span-12 md:col-span-9">
          <h2 class="font-display tracking-[-0.02em] uppercase text-[10vw] md:text-[5vw] leading-[0.92] max-w-[12ch]" data-anim-h2>
            <span class="sr-only">Acquire or commission</span>
            {["Acquire", "or commission"].map((line, i) => (
              <span class="block overflow-hidden" aria-hidden="true">
                <span class="block anim-line" style={`--i:${i}`}>{line}</span>
              </span>
            ))}
          </h2>
          <p class="mt-8 max-w-xl text-[16px] md:text-[18px] leading-[1.7] text-ink/80">
            Vitaly accepts a small number of commissions each year and works directly
            with galleries and private collectors. Write below — every message is
            read and replied to.
          </p>

          <form
            class="mt-14 md:mt-20 max-w-xl"
            data-contact-form
            method="POST"
            action="https://api.web3forms.com/submit"
            novalidate
          >
            {/* Web3Forms config */}
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="from_name" value="Vitality Art — Website" />
            <input type="hidden" name="subject" value="New inquiry from vitalityart.es" />
            <input type="hidden" name="redirect" value="false" />
            {/* CC recipients are configured in the Web3Forms dashboard, not via form field. */}
            {/* Honeypot — bots fill this, humans don't see it */}
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
            {/* Hidden context — auto-filled if user came from a PDP "Acquire" link with ?painting=… */}
            <input type="hidden" name="painting_reference" value="" data-painting-ref />

            <div class="flex flex-col gap-8 md:gap-10">
              <label class="block">
                <span class="block text-[11px] tracking-[0.2em] uppercase text-ink/55 mb-2">Name</span>
                <input
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  class="block w-full pb-3 text-[16px] md:text-[18px] bg-transparent border-b border-ink/20 focus:border-ink outline-none transition-colors duration-300"
                />
              </label>

              <label class="block">
                <span class="block text-[11px] tracking-[0.2em] uppercase text-ink/55 mb-2">Email</span>
                <input
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="block w-full pb-3 text-[16px] md:text-[18px] bg-transparent border-b border-ink/20 focus:border-ink outline-none transition-colors duration-300"
                />
              </label>

              <label class="block">
                <span class="block text-[11px] tracking-[0.2em] uppercase text-ink/55 mb-2">Message</span>
                <textarea
                  name="message"
                  required
                  rows="5"
                  class="block w-full pb-3 text-[16px] md:text-[18px] bg-transparent border-b border-ink/20 focus:border-ink outline-none transition-colors duration-300 resize-none"
                ></textarea>
              </label>
            </div>

            <div class="mt-10 md:mt-12 flex items-center gap-6 flex-wrap">
              <button
                type="submit"
                class="group inline-flex items-center h-12 gap-3 pl-5 pr-1.5 rounded-full bg-ink text-bone hover:bg-ink/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] text-[11px] tracking-[0.2em] uppercase cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                data-submit-btn
              >
                <span data-submit-label>Send message</span>
                <span class="w-9 h-9 rounded-full bg-bone/15 grid place-items-center text-bone group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">↗</span>
              </button>
              <p class="text-[11px] tracking-[0.2em] uppercase text-ink/45 hidden" data-form-status></p>
            </div>

            {/* Painting context indicator (hidden by default; shown when ?painting= URL param is present) */}
            <p class="mt-6 text-[11px] tracking-[0.2em] uppercase text-ink/55 hidden" data-painting-context>
              Inquiring about: <span data-painting-name class="text-ink"></span>
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 07 · FOOTER                                                   -->
    <!-- ============================================================ -->
    <footer class="bg-bone border-t border-ink/15 px-6 md:px-10 pt-12 md:pt-16 pb-32 md:pb-32 grid grid-cols-12 gap-6 md:gap-10 text-[11px] tracking-[0.2em] uppercase text-ink/60">
      <span class="col-span-12 md:col-span-4">© Vitaly Leshukov · 2026</span>
      <div class="col-span-6 md:col-span-4 flex flex-col md:flex-row gap-3 md:gap-6">
        <a href="#" class="hover:text-ink transition-colors duration-500">Instagram</a>
        <a href="#" class="hover:text-ink transition-colors duration-500">Facebook</a>
        <a href="#" class="hover:text-ink transition-colors duration-500">TikTok</a>
      </div>
      <span class="col-span-6 md:col-span-4 text-right">vitalityart.es</span>
    </footer>
  </main>
</Base>

<style>
  /* === Lenis smooth scroll required CSS === */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-smooth iframe { pointer-events: none; }

  /* === Marquee — JS-driven, scroll-coupled (see script) === */
  [data-marquee] { transform: translate3d(0, 0, 0); }

  /* === Parallax-driven cards: y is set per scroll, no inline transform on the card === */
  [data-parallax-card] {
    transform: translate3d(0, var(--parallax-y, 0px), 0);
    will-change: transform;
  }
  /* Tilt happens on an inner wrapper so it composes cleanly with the parent's parallax-y */
  .tilt-card { perspective: 1200px; }
  .tilt-inner {
    transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 600ms cubic-bezier(0.32, 0.72, 0, 1);
    transform-style: preserve-3d;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-parallax-card] { transform: none !important; }
    .tilt-inner { transform: none !important; transition: none !important; }
  }

  /* === Scroll reveal === */
  [data-reveal] {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    filter: blur(6px);
    transition:
      opacity 900ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 900ms cubic-bezier(0.32, 0.72, 0, 1),
      filter 900ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: opacity, transform, filter;
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }

  /* ============================================================
     Text animations from animate-text skill
     ============================================================ */

  /* === soft-blur-in (per-character) — Apple-signature hero reveal ===
     Spec: enter 900ms, stagger 25ms, ease cubic-bezier(0.22,1,0.36,1)
           from { opacity:0, y:16px, blur:12px } to { 0,0,0 } */
  @keyframes anim-char {
    from {
      opacity: 0;
      transform: translate3d(0, 16px, 0);
      filter: blur(12px);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }
  }
  .anim-char {
    opacity: 0;
    animation: anim-char 900ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i, 0) * 25ms);
    will-change: opacity, transform, filter;
  }
  /* Mask the parent line to clip any sub-pixel bleed during blur */
  .anim-line-mask {
    overflow: hidden;
    padding-bottom: 0.05em;
    margin-bottom: -0.05em;
  }

  /* === mask-reveal-up (per-line) — used on quote + section H2s ===
     Spec: enter 760ms, stagger 90ms, ease cubic-bezier(0.22,1,0.36,1)
           from { opacity:0, y:30px, blur:6px } to { 0,0,0 } */
  @keyframes anim-line {
    from {
      opacity: 0;
      transform: translate3d(0, 30px, 0);
      filter: blur(6px);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }
  }
  .anim-line {
    opacity: 0;
    animation: anim-line 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    /* Hero quote follows the name (~600ms) by default; section H2s reset this via the trigger */
    animation-delay: calc(600ms + var(--i, 0) * 90ms);
    will-change: opacity, transform, filter;
  }

  /* H2s start paused — wait for IntersectionObserver to flip a class */
  [data-anim-h2] .anim-line {
    animation-play-state: paused;
    animation-delay: calc(var(--i, 0) * 90ms);
  }
  [data-anim-h2].is-animated .anim-line {
    animation-play-state: running;
  }

  /* === Hero divider — small fade-in following the name === */
  @keyframes anim-divider {
    from { opacity: 0; transform: scaleX(0.2); }
    to   { opacity: 1; transform: scaleX(1); }
  }
  .anim-divider {
    transform-origin: left center;
    opacity: 0;
    animation: anim-divider 700ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 500ms;
  }

  /* === Reduced motion: hard-cut all === */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
    .anim-char,
    .anim-line,
    .anim-divider {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }
  }
</style>

<script>
  import Lenis from "lenis";

  // === Lenis smooth scroll ===
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let lenis: Lenis | null = null;

  if (!reduced) {
    lenis = new Lenis({
      lerp: 0.1,
      wheelMultiplier: 1,
      // Touch on mobile: keep native momentum (smoother on iOS)
      smoothWheel: true,
      syncTouch: false,
    });
    const raf = (time: number) => {
      lenis?.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  }

  // === Parallax — card-level + intra-card image ===
  const parallaxCards = Array.from(
    document.querySelectorAll<HTMLElement>("[data-parallax-card]"),
  );
  const parallaxImgs = Array.from(
    document.querySelectorAll<HTMLImageElement>("[data-parallax-img]"),
  );

  const updateParallax = () => {
    const vh = window.innerHeight;
    for (const card of parallaxCards) {
      const rect = card.getBoundingClientRect();
      // Skip if completely off-screen (perf)
      if (rect.bottom < -200 || rect.top > vh + 200) continue;
      const center = rect.top + rect.height / 2;
      const distance = (center - vh / 2) / vh; // ~ -1 .. +1 across viewport
      const speed = parseFloat(card.dataset.speed || "0");
      const y = distance * speed * 100;
      card.style.setProperty("--parallax-y", `${y.toFixed(2)}px`);
    }
    for (const img of parallaxImgs) {
      const cardEl = img.closest<HTMLElement>("[data-parallax-card]");
      if (!cardEl) continue;
      const rect = cardEl.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > vh + 200) continue;
      const center = rect.top + rect.height / 2;
      const distance = (center - vh / 2) / vh;
      const speed = parseFloat(img.dataset.speed || "0");
      const y = distance * speed * 100;
      // Image is 120% tall starting at -10% top — parallax stays inside the frame
      img.style.transform = `translate3d(0, ${y.toFixed(2)}px, 0)`;
    }
  };

  if (!reduced && parallaxCards.length) {
    if (lenis) {
      lenis.on("scroll", updateParallax);
    } else {
      window.addEventListener("scroll", updateParallax, { passive: true });
    }
    window.addEventListener("resize", updateParallax);
    updateParallax();
  }

  // === Gallery overlay — fades dark bg in/out as works section enters/leaves ===
  const overlay = document.querySelector<HTMLElement>("[data-gallery-overlay]");
  const gallerySection = document.querySelector<HTMLElement>("[data-gallery-section]");
  if (overlay && gallerySection && "IntersectionObserver" in window) {
    const galleryIo = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          // Reverses smoothly in either direction since the transition runs both ways
          overlay.style.opacity = e.isIntersecting ? "1" : "0";
        }
      },
      // Trigger as soon as the section's top reaches 25% from the bottom of viewport
      { rootMargin: "-25% 0px -25% 0px", threshold: 0 },
    );
    galleryIo.observe(gallerySection);
  }

  // === Cursor tilt — paintings tilt subtly toward the mouse ===
  const tiltCards = Array.from(document.querySelectorAll<HTMLElement>("[data-tilt]"));
  if (!reduced && tiltCards.length && window.matchMedia("(hover: hover)").matches) {
    const MAX_DEG = 5; // max tilt angle in degrees
    for (const card of tiltCards) {
      const inner = card.querySelector<HTMLElement>(".tilt-inner");
      if (!inner) continue;
      const reset = () => {
        inner.style.setProperty("--tilt-x", "0deg");
        inner.style.setProperty("--tilt-y", "0deg");
      };
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width;
        const py = (e.clientY - rect.top) / rect.height;
        // tilt-y rotates around vertical axis (left/right), tilt-x rotates around horizontal axis (up/down)
        const ry = (px - 0.5) * 2 * MAX_DEG;     // -MAX..+MAX
        const rx = -(py - 0.5) * 2 * MAX_DEG;    // invert so leaning into cursor
        inner.style.setProperty("--tilt-x", `${rx.toFixed(2)}deg`);
        inner.style.setProperty("--tilt-y", `${ry.toFixed(2)}deg`);
      });
      card.addEventListener("mouseleave", reset);
    }
  }

  // === Marquee — scroll-coupled with ambient drift ===
  // Always drifts left at a small base speed. Scroll velocity adds on top:
  // scrolling down accelerates left, scrolling up reverses (with inertia
  // via lerp). Removes stars; just images and text labels.
  const marquee = document.querySelector<HTMLElement>("[data-marquee]");
  const marqueeTrack = marquee?.querySelector<HTMLElement>("[data-marquee-track]");
  if (marquee && marqueeTrack && !reduced) {
    let trackWidth = marqueeTrack.offsetWidth;
    const measure = () => { trackWidth = marqueeTrack.offsetWidth; };
    measure();
    window.addEventListener("resize", measure);

    let position = 0;       // current x in px (negative = moved left)
    let velocity = 0;       // current per-frame velocity
    let targetVelocity = -1.6; // ambient drift, 20% slower than previous tune
    const baseDrift = -1.6;
    const lerp = 0.08;       // inertia smoothness

    const onScroll = (e: { velocity?: number }) => {
      // lenis velocity is in px/frame-ish; scale and add to target
      const v = typeof e.velocity === "number" ? e.velocity : 0;
      // Scrolling down (positive v) → marquee accelerates left (more negative).
      // Scrolling up (negative v) → marquee reverses right (positive).
      targetVelocity = baseDrift + v * -1.4;
    };
    if (lenis) {
      lenis.on("scroll", onScroll);
    } else {
      let lastY = window.scrollY;
      window.addEventListener("scroll", () => {
        const y = window.scrollY;
        const v = y - lastY;
        lastY = y;
        targetVelocity = baseDrift + v * -1.4;
      }, { passive: true });
    }

    const decay = 0.93;
    const tick = () => {
      // Inertia toward the current target, then bleed target back to baseDrift
      velocity += (targetVelocity - velocity) * lerp;
      targetVelocity = baseDrift + (targetVelocity - baseDrift) * decay;

      position += velocity;
      // Wrap modulo trackWidth (so doubled track loops seamlessly)
      if (trackWidth > 0) {
        if (position <= -trackWidth) position += trackWidth;
        if (position > 0) position -= trackWidth;
      }
      marquee.style.transform = `translate3d(${position.toFixed(2)}px, 0, 0)`;
      requestAnimationFrame(tick);
    };
    tick();
  }

  // === Hook anchor clicks into lenis for smooth jumps ===
  if (lenis) {
    const anchors = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'),
    );
    for (const a of anchors) {
      a.addEventListener("click", (e) => {
        const href = a.getAttribute("href");
        if (!href || href === "#") return;
        const target = document.querySelector<HTMLElement>(href);
        if (!target) return;
        e.preventDefault();
        lenis!.scrollTo(target, { offset: -96, duration: 1.4 });
        history.pushState(null, "", href);
      });
    }
  }

  // === Section reveal observer ===
  const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
  if (revealEls.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-revealed");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -10% 0px" },
    );
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add("is-revealed"));
  }

  // === H2 mask-reveal-up trigger ===
  const h2Els = document.querySelectorAll<HTMLElement>("[data-anim-h2]");
  if (h2Els.length && "IntersectionObserver" in window) {
    const h2io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-animated");
            h2io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.3, rootMargin: "0px 0px -8% 0px" },
    );
    h2Els.forEach((el) => h2io.observe(el));
  } else {
    h2Els.forEach((el) => el.classList.add("is-animated"));
  }

  // === Active section indicator for floating nav ===
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-anchor-link]"));
  const sectionMap = new Map<string, HTMLAnchorElement>();
  navLinks.forEach((a) => {
    const href = a.getAttribute("data-anchor-link");
    if (href) sectionMap.set(href.replace("#", ""), a);
  });
  const sections = Array.from(sectionMap.keys())
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => Boolean(el));

  if (sections.length && "IntersectionObserver" in window) {
    const setActive = (id: string | null) => {
      navLinks.forEach((a) => {
        const target = a.getAttribute("data-anchor-link")?.replace("#", "");
        const isContact = target === "contact";
        const isActive = target === id;
        if (isContact) return; // Contact button keeps its primary styling
        a.classList.toggle("text-ink", isActive);
        a.classList.toggle("text-ink/70", !isActive);
        a.classList.toggle("bg-ink/[0.06]", isActive);
      });
    };
    const navIo = new IntersectionObserver(
      (entries) => {
        // Prefer the section closest to the middle of the viewport
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length) setActive(visible[0].target.id);
      },
      { rootMargin: "-40% 0px -40% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] },
    );
    sections.forEach((s) => navIo.observe(s));
  }

  // === Contact form (Web3Forms) ===
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  if (form) {
    const statusEl = form.querySelector<HTMLElement>("[data-form-status]");
    const submitBtn = form.querySelector<HTMLButtonElement>("[data-submit-btn]");
    const submitLabel = form.querySelector<HTMLElement>("[data-submit-label]");

    // If the URL has ?painting=… (from PDP "Acquire" link), prefill context
    const params = new URLSearchParams(window.location.search);
    const painting = params.get("painting");
    if (painting) {
      const ctxEl = form.querySelector<HTMLElement>("[data-painting-context]");
      const nameEl = form.querySelector<HTMLElement>("[data-painting-name]");
      const refInput = form.querySelector<HTMLInputElement>("[data-painting-ref]");
      if (ctxEl) ctxEl.classList.remove("hidden");
      if (nameEl) nameEl.textContent = painting;
      if (refInput) refInput.value = painting;
      // Pre-fill the message body with a friendly opener
      const msg = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
      if (msg && !msg.value) msg.value = `Hi Vitaly,\n\nI'm interested in "${painting}". `;
    }

    const setStatus = (text: string, kind: "ok" | "err" | "info") => {
      if (!statusEl) return;
      statusEl.textContent = text;
      statusEl.classList.remove("hidden", "text-ink/45", "text-ink", "text-[#a83232]");
      statusEl.classList.add(
        kind === "ok"  ? "text-ink"
        : kind === "err" ? "text-[#a83232]"
        : "text-ink/45",
      );
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn) return;
      submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = "Sending…";
      setStatus("", "info");

      try {
        const data = new FormData(form);
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: data,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          if (submitLabel) submitLabel.textContent = "Sent ✓";
          setStatus("Thanks — Vitaly will reply within a few days.", "ok");
        } else {
          submitBtn.disabled = false;
          if (submitLabel) submitLabel.textContent = "Send message";
          setStatus(json.message || "Something went wrong. Try again or email viacatalana@gmail.com.", "err");
        }
      } catch (err) {
        submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = "Send message";
        setStatus("Network error. Try again or email viacatalana@gmail.com.", "err");
      }
    });
  }

  // === Events / Exhibitions tabs ===
  const tabsRoot = document.querySelector<HTMLElement>("[data-tabs]");
  if (tabsRoot) {
    const tabButtons = Array.from(tabsRoot.querySelectorAll<HTMLButtonElement>("[data-tab]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-tab-panel]"));
    const setTab = (key: string) => {
      for (const btn of tabButtons) {
        const isActive = btn.dataset.tab === key;
        btn.setAttribute("aria-selected", String(isActive));
        btn.classList.toggle("bg-ink", isActive);
        btn.classList.toggle("text-bone", isActive);
        btn.classList.toggle("text-ink/65", !isActive);
        btn.classList.toggle("hover:text-ink", !isActive);
      }
      for (const panel of panels) {
        panel.classList.toggle("hidden", panel.dataset.tabPanel !== key);
      }
    };
    for (const btn of tabButtons) {
      btn.addEventListener("click", () => setTab(btn.dataset.tab || "events"));
    }
  }

  // === Hero rotator ===
  const rotator = document.querySelector<HTMLElement>("[data-hero-rotator]");
  if (rotator) {
    const slides = Array.from(rotator.querySelectorAll<HTMLImageElement>("[data-hero-slide]"));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"));
    const titleEl = document.querySelector<HTMLElement>("[data-hero-title]");
    const yearEl = document.querySelector<HTMLElement>("[data-hero-year]");
    const dimsEl = document.querySelector<HTMLElement>("[data-hero-dims]");

    // Read metadata from the data placeholders we already rendered
    const meta = slides.map((img) => ({
      title: img.alt.split(",")[0],
      year: img.dataset.year || "",
      dims: img.dataset.dims || "",
    }));

    let active = 0;
    let timer: number | undefined;
    let paused = false;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const goTo = (next: number) => {
      slides[active].style.opacity = "0";
      slides[next].style.opacity = "1";
      dots.forEach((d, i) => {
        d.classList.toggle("text-ink", i === next);
        d.classList.toggle("text-ink/35", i !== next);
      });
      if (titleEl) titleEl.textContent = meta[next].title;
      if (yearEl) yearEl.textContent = meta[next].year;
      if (dimsEl) dimsEl.textContent = meta[next].dims;
      active = next;
    };

    const tick = () => {
      if (paused) return;
      goTo((active + 1) % slides.length);
    };

    if (!reduced && slides.length > 1) {
      timer = window.setInterval(tick, 6000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        // Reset the auto-cycle so the manual choice gets full time
        if (timer) {
          clearInterval(timer);
          if (!reduced) timer = window.setInterval(tick, 6000);
        }
      });
    });

    rotator.addEventListener("mouseenter", () => { paused = true; });
    rotator.addEventListener("mouseleave", () => { paused = false; });
  }
</script>
