---
import Base from "~/layouts/Base.astro";
---

<Base>
  <main class="min-h-screen flex flex-col justify-between p-8 md:p-16">
    <header class="flex justify-between items-baseline">
      <span class="font-sans text-sm tracking-widest uppercase">Vitality Art</span>
      <span class="font-sans text-sm text-ink/60">Est. 2026</span>
    </header>

    <section class="py-24 md:py-32">
      <p class="font-sans text-sm tracking-widest uppercase text-ink/60 mb-6">
        Phase 1 — Scaffold
      </p>
      <h1 class="font-display tracking-display text-[15vw] leading-[0.9] uppercase">
        Hello,<br />Vitaly
      </h1>
      <p class="font-sans mt-8 max-w-xl text-lg text-ink/80">
        A new home for the work of Vitaly Leshukov. Built quietly, in two tones —
        bone and ink — so the paintings carry the color.
      </p>
    </section>

    <footer class="flex justify-between items-baseline text-sm text-ink/60">
      <span class="font-sans">Type check: Tanker + General Sans</span>
      <span class="font-sans">vitalityart.es</span>
    </footer>
  </main>
</Base>
